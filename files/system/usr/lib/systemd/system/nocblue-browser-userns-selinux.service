[Unit]
Description=Sync nocblue browser sandbox SELinux policy
ConditionSecurity=selinux
ConditionPathExists=/usr/share/nocblue/selinux/browser-userns/nocblue_browser_userns.cil
After=local-fs.target
Before=display-manager.service

[Service]
Type=oneshot
ExecStart=/usr/bin/nocblue-sync-browser-userns-selinux

[Install]
WantedBy=multi-user.target
