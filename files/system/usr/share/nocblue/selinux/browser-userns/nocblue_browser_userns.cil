(type brave_origin_t)
(type brave_origin_exec_t)
(type helium_t)
(type helium_exec_t)

(roletype unconfined_r brave_origin_t)
(roletype unconfined_r helium_t)
(roletype object_r brave_origin_exec_t)
(roletype object_r helium_exec_t)

(typeattributeset domain (brave_origin_t helium_t))
(typeattributeset application_domain_type (brave_origin_t helium_t))
(typeattributeset unconfined_domain_type (brave_origin_t helium_t))
(typeattributeset file_type (brave_origin_exec_t helium_exec_t))
