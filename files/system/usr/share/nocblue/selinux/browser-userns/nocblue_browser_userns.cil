(typeattributeset non_security_file_type (brave_origin_exec_t helium_exec_t))

(allow unconfined_t brave_origin_exec_t (file (getattr open read execute map)))
(allow unconfined_t helium_exec_t (file (getattr open read execute map)))
(allow unconfined_t brave_origin_t (process (transition)))
(allow unconfined_t helium_t (process (transition)))

(typetransition unconfined_t brave_origin_exec_t process brave_origin_t)
(typetransition unconfined_t helium_exec_t process helium_t)

(allow brave_origin_t brave_origin_exec_t (file (entrypoint execute read getattr open map)))
(allow helium_t helium_exec_t (file (entrypoint execute read getattr open map)))
(allow brave_origin_t brave_origin_exec_t (file (execute_no_trans)))
(allow helium_t helium_exec_t (file (execute_no_trans)))
(allow brave_origin_t unconfined_t (process (sigchld rlimitinh noatsecure)))
(allow helium_t unconfined_t (process (sigchld rlimitinh noatsecure)))
(allow brave_origin_t unconfined_t (fd (use)))
(allow helium_t unconfined_t (fd (use)))
(allow brave_origin_t unconfined_t (fifo_file (getattr read write append ioctl lock open)))
(allow helium_t unconfined_t (fifo_file (getattr read write append ioctl lock open)))

(allow brave_origin_t brave_origin_t (user_namespace (create)))
(allow helium_t helium_t (user_namespace (create)))

