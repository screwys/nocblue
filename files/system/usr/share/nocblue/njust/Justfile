default:
    just --justfile {{justfile()}} --list

status:
    rpm-ostree status || true
    bootc status || true

update:
    sudo bootc upgrade
    flatpak update --system -y
    flatpak update --user -y || true
    if command -v brew >/dev/null 2>&1; then brew update && brew upgrade; fi

auto-update-status:
    systemctl status bootc-fetch-apply-updates.timer --no-pager || true
    systemctl status flatpak-system-update.timer --no-pager || true
    systemctl --user status flatpak-user-update.timer --no-pager || true
    systemctl --user status secureblue-flatpak-setup.timer nocblue-flatpak-setup.timer --no-pager || true
    systemctl list-timers bootc-fetch-apply-updates.timer flatpak-system-update.timer --no-pager || true
    systemctl --user list-timers flatpak-user-update.timer secureblue-flatpak-setup.timer nocblue-flatpak-setup.timer --no-pager || true

rollback:
    sudo rpm-ostree rollback

flatpaks:
    flatpak list --app

flatpak-icon-fixes:
    nocblue-fix-flatpak-icons

flatpak-overrides:
    sudo nocblue-apply-flatpak-overrides

flatpak-overrides-user:
    nocblue-apply-flatpak-overrides --user

flatpaks-repair:
    nocblue-setup-flatpaks --repair

brew:
    brew update
    brew upgrade

android-sdk api="36" build_tools="36.0.0":
    ANDROID_BUILD_TOOLS="{{build_tools}}" nocblue-setup-android-sdk "{{api}}"

secureboot-check:
    mokutil --sb-state || true
    mokutil --list-enrolled | grep -E "nocblue|ublue kernel" || true

fde-list:
    nocblue-fde-helper list

fde-status device:
    nocblue-fde-helper status "{{device}}"

fde-tpm2 device pin="yes" pcrs="7":
    sudo nocblue-fde-helper tpm2-enroll "{{device}}" "{{pin}}" "{{pcrs}}"

fde-recovery-key device:
    sudo nocblue-fde-helper recovery-key "{{device}}"

tests:
    nocblue-tests

container-userns mode="status":
    ujust set-container-userns "{{mode}}"

unconfined-userns mode="status":
    ujust set-unconfined-userns "{{mode}}"
