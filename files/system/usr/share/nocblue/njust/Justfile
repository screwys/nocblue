default:
    just --justfile {{justfile()}} --list

status:
    rpm-ostree status || true
    bootc status || true

update:
    sudo bootc upgrade
    flatpak update --system -y
    flatpak update --user -y || true
    if command -v brew >/dev/null 2>&1; then brew update && brew upgrade; fi

auto-update-status:
    systemctl status bootc-fetch-apply-updates.timer --no-pager || true
    systemctl status flatpak-system-update.timer --no-pager || true
    systemctl --user status flatpak-user-update.timer --no-pager || true
    systemctl --user status secureblue-flatpak-setup.timer nocblue-flatpak-setup.timer --no-pager || true
    systemctl list-timers bootc-fetch-apply-updates.timer flatpak-system-update.timer --no-pager || true
    systemctl --user list-timers flatpak-user-update.timer secureblue-flatpak-setup.timer nocblue-flatpak-setup.timer --no-pager || true

rollback:
    sudo rpm-ostree rollback

flatpaks:
    flatpak list --app

flatpak-icon-fixes:
    nocblue-fix-flatpak-icons

flatpak-overrides:
    sudo nocblue-apply-flatpak-overrides

flatpak-overrides-user:
    nocblue-apply-flatpak-overrides --user

flatpaks-repair:
    nocblue-setup-flatpaks --repair

brew:
    brew update
    brew upgrade

android-sdk api="36" build_tools="36.0.0":
    ANDROID_BUILD_TOOLS="{{build_tools}}" nocblue-setup-android-sdk "{{api}}"

image action="" scope="":
    #!/usr/bin/env bash
    set -euo pipefail

    action="{{action}}"
    scope="{{scope}}"
    user_policy="${XDG_CONFIG_HOME:-$HOME/.config}/containers/policy.json"

    usage() {
        printf '%s\n' \
            'usage:' \
            '  njust image trust REGISTRY_OR_REPOSITORY' \
            '  njust image trust-user REGISTRY_OR_REPOSITORY' \
            '  njust image trust-show' \
            '  njust image trust-show-user' \
            '  njust image check-secureblue'
    }

    require_scope() {
        if [ -z "${scope}" ]; then
            usage >&2
            exit 2
        fi
    }

    privileged() {
        if command -v run0 >/dev/null 2>&1; then
            run0 "$@"
        else
            sudo "$@"
        fi
    }

    set_user_trust() {
        local tmp
        mkdir -p "$(dirname "${user_policy}")"
        if [ ! -f "${user_policy}" ]; then
            if [ -f /etc/containers/policy.json ]; then
                cp /etc/containers/policy.json "${user_policy}"
            elif [ -f /usr/etc/containers/policy.json ]; then
                cp /usr/etc/containers/policy.json "${user_policy}"
            else
                printf '{"default":[{"type":"reject"}],"transports":{"docker":{"":[{"type":"reject"}]}}}\n' >"${user_policy}"
            fi
        fi

        tmp="$(mktemp)"
        jq --arg scope "${scope}" \
            '.transports.docker[$scope] = [{"type": "insecureAcceptAnything"}]' \
            "${user_policy}" >"${tmp}"
        mv "${tmp}" "${user_policy}"
    }

    case "${action}" in
        check-secureblue)
            nocblue-check-secureblue-base
            ;;
        trust)
            require_scope
            privileged podman image trust set -t accept "${scope}"
            ;;
        trust-user)
            require_scope
            set_user_trust
            podman image trust show --policypath "${user_policy}" | grep -E "(^TRANSPORT|${scope})" || true
            ;;
        trust-show)
            privileged podman image trust show
            ;;
        trust-show-user)
            podman image trust show --policypath "${user_policy}"
            ;;
        *)
            usage >&2
            exit 2
            ;;
    esac

secureboot-check:
    mokutil --sb-state || true
    mokutil --list-enrolled | grep -E "nocblue|ublue kernel" || true

fde-list:
    nocblue-fde-helper list

fde-status device:
    nocblue-fde-helper status "{{device}}"

fde-tpm2 device pin="yes" pcrs="7":
    sudo nocblue-fde-helper tpm2-enroll "{{device}}" "{{pin}}" "{{pcrs}}"

fde-recovery-key device:
    sudo nocblue-fde-helper recovery-key "{{device}}"

tests:
    nocblue-tests

container-userns mode="status":
    #!/usr/bin/env bash
    set -euo pipefail

    mode="{{mode}}"
    ujust_list=""
    if command -v ujust >/dev/null 2>&1; then
        ujust_list="$(ujust --list)"
    fi

    if grep -Eq '^[[:space:]]*set-container-userns([[:space:]]|$)' <<<"${ujust_list}"; then
        ujust set-container-userns "${mode}"
    elif [[ "${mode}" == "status" ]]; then
        printf 'unavailable\n'
    else
        printf 'secureblue set-container-userns is not available on this image\n' >&2
        exit 2
    fi

unconfined-userns mode="status":
    #!/usr/bin/env bash
    set -euo pipefail

    mode="{{mode}}"
    ujust_list=""
    if command -v ujust >/dev/null 2>&1; then
        ujust_list="$(ujust --list)"
    fi

    if grep -Eq '^[[:space:]]*set-unconfined-userns([[:space:]]|$)' <<<"${ujust_list}"; then
        ujust set-unconfined-userns "${mode}"
    elif [[ "${mode}" == "status" ]]; then
        printf 'unavailable\n'
    else
        printf 'secureblue set-unconfined-userns is not available on this image\n' >&2
        exit 2
    fi
