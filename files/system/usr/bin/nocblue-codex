#!/usr/bin/env bash
set -euo pipefail

shim_dir=/usr/libexec/nocblue/codex-bwrap-path

if [[ -x "${shim_dir}/bwrap" ]]; then
    case ":${PATH}:" in
        *":${shim_dir}:"*) ;;
        *) export PATH="${shim_dir}:${PATH}" ;;
    esac
fi

real_codex=
while IFS= read -r candidate; do
    [[ -n "${candidate}" ]] || continue
    case "$(readlink -f "${candidate}" 2>/dev/null || printf '%s\n' "${candidate}")" in
        /usr/bin/nocblue-codex|/usr/libexec/nocblue/codex-bwrap/*)
            continue
            ;;
    esac
    real_codex="${candidate}"
    break
done < <(type -P -a codex 2>/dev/null || true)

if [[ -z "${real_codex}" ]]; then
    printf 'nocblue-codex: codex was not found on PATH\n' >&2
    exit 127
fi

exec "${real_codex}" "$@"
