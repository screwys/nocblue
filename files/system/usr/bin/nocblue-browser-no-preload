#!/usr/bin/env bash
set -euo pipefail

if [[ "$#" -lt 1 ]]; then
    printf 'usage: %s COMMAND [ARGS...]\n' "$0" >&2
    exit 2
fi

unset LD_PRELOAD

if [[ -r /etc/ld.so.preload ]]; then
    exec bwrap \
        --dev-bind / / \
        --cap-drop ALL \
        --ro-bind-try /dev/null /etc/ld.so.preload \
        --setenv LD_PRELOAD "" \
        -- "$@"
fi

exec "$@"
