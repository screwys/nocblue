#!/usr/bin/env bash
set -euo pipefail

if [[ "$#" -lt 1 ]]; then
    printf 'usage: %s COMMAND [ARGS...]\n' "$0" >&2
    exit 2
fi

allowed_browser_command() {
    case "$1" in
        /opt/brave.com/brave-origin-beta/brave-origin-beta|\
        /usr/lib/opt/brave.com/brave-origin-beta/brave-origin-beta|\
        /opt/brave.com/brave-origin-beta/brave|\
        /usr/lib/opt/brave.com/brave-origin-beta/brave|\
        /opt/brave.com/brave-beta/brave-browser-beta|\
        /usr/lib/opt/brave.com/brave-beta/brave-browser-beta|\
        /opt/brave.com/brave/brave-browser|\
        /usr/lib/opt/brave.com/brave/brave-browser|\
        /opt/helium/helium-wrapper|\
        /usr/lib/opt/helium/helium-wrapper|\
        /opt/helium/helium|\
        /usr/lib/opt/helium/helium|\
        /usr/bin/firefox|\
        /usr/lib64/firefox/firefox|\
        /usr/share/librewolf/librewolf|\
        /usr/share/librewolf/librewolf-bin|\
        /usr/lib/mullvad-browser/start-mullvad-browser|\
        /usr/lib/mullvad-browser/mullvadbrowser|\
        /usr/lib/mullvad-browser/mullvadbrowser.real)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

resolve_browser_command() {
    local command="$1"
    local path resolved

    if [[ "${command}" == */* ]]; then
        path="${command}"
    else
        path="$(command -v -- "${command}" 2>/dev/null || true)"
    fi

    resolved="$(readlink -f -- "${path}" 2>/dev/null || true)"
    if [[ -z "${resolved}" || ! -x "${resolved}" ]]; then
        printf 'nocblue-browser-no-preload cannot find executable browser command: %s\n' "${command}" >&2
        exit 126
    fi

    case "${resolved}" in
        /usr/bin/firefox)
            if [[ -x /usr/lib64/firefox/firefox ]]; then
                resolved="/usr/lib64/firefox/firefox"
            fi
            ;;
    esac

    if ! allowed_browser_command "${resolved}"; then
        printf 'nocblue-browser-no-preload refuses unsupported browser command: %s\n' "${command}" >&2
        exit 126
    fi

    printf '%s\n' "${resolved}"
}

restore_session_env() {
    local name value

    if [[ -n "${WAYLAND_DISPLAY:-}" || -n "${DISPLAY:-}" ]]; then
        return 0
    fi

    while IFS='=' read -r name value; do
        case "${name}" in
            DISPLAY|WAYLAND_DISPLAY|NIRI_SOCKET|XDG_CURRENT_DESKTOP|XDG_SESSION_DESKTOP|XDG_SESSION_TYPE)
                if [[ -n "${value}" && -z "${!name:-}" ]]; then
                    export "${name}=${value}"
                fi
                ;;
        esac
    done < <(systemctl --user show-environment 2>/dev/null || true)
}

restore_session_env
unset LD_PRELOAD
export NOCBLUE_BROWSER_NO_PRELOAD=1
browser_command="$(resolve_browser_command "$1")"
shift
set -- "${browser_command}" "$@"

if [[ -r /etc/ld.so.preload ]]; then
    exec bwrap \
        --dev-bind / / \
        --cap-drop ALL \
        --ro-bind-try /dev/null /etc/ld.so.preload \
        --setenv LD_PRELOAD "" \
        --setenv NOCBLUE_BROWSER_NO_PRELOAD "1" \
        -- "$@"
fi

exec "$@"
