#!/usr/bin/env bash
set -euo pipefail

fedora_version="$(rpm -E %fedora)"
test "${fedora_version}" = "44"

rpm -q kernel kernel-core kernel-modules-core >/dev/null
! rpm -q kernel-cachyos kernel-cachyos-devel-matched cachyos-settings >/dev/null 2>&1
! find /usr/lib/modules -maxdepth 1 -mindepth 1 -type d -name '*cachyos*' | grep -q .

for cmd in niri qs fish fastfetch wl-copy wl-paste wf-recorder wl-screenrec kdeconnectd firefox librewolf trivalent zed torbrowser-launcher magick tesseract ujust; do
    command -v "${cmd}" >/dev/null 2>&1 || {
        printf 'missing expected command: %s\n' "${cmd}" >&2
        exit 1
    }
done

if [[ -d /etc/xdg/quickshell/noctalia-shell || -d /usr/share/quickshell/noctalia-shell || -d /usr/share/noctalia-shell ]]; then
    :
else
    printf 'missing noctalia-shell runtime\n' >&2
    exit 1
fi

rpm -q ghostty input-remapper ImageMagick tesseract tesseract-langpack-eng tesseract-langpack-jpn tesseract-langpack-jpn_vert google-noto-sans-cjk-fonts radicale3 radicale3-selinux protonvpn-beta-release proton-vpn-gnome-desktop hardened_malloc no_rlimit_as >/dev/null
! rpm -q protonvpn-stable-release >/dev/null 2>&1
for pkg in ptyxis gnome-terminal gnome-terminal-nautilus gnome-console kgx; do
    ! rpm -q "${pkg}" >/dev/null 2>&1 || {
        printf 'removed terminal package is still installed: %s\n' "${pkg}" >&2
        exit 1
    }
done

test -x /usr/bin/ghostty
test ! -e /usr/local/bin/ghostty
grep -q 'Fedora-Silverblue' /etc/xdg/fastfetch/config.jsonc
grep -q "Nocblue 44" /etc/xdg/fastfetch/config.jsonc
grep -q 'x86_64$//' /etc/xdg/fastfetch/config.jsonc
test -f /usr/lib/systemd/system/brew-setup.service
test -f /usr/lib/systemd/system/bootc-fetch-apply-updates.service
test -f /usr/lib/systemd/system/bootc-fetch-apply-updates.timer
test -f /usr/lib/systemd/system/flatpak-system-update.service
test -f /usr/lib/systemd/system/flatpak-system-update.timer
grep -q '^ExecStart=/usr/bin/bootc upgrade --apply --quiet$' /usr/lib/systemd/system/bootc-fetch-apply-updates.service
test -L /etc/systemd/system/timers.target.wants/bootc-fetch-apply-updates.timer
test -L /etc/systemd/system/timers.target.wants/flatpak-system-update.timer
test -L /etc/systemd/system/multi-user.target.wants/nocblue-hardened-malloc-flatpaks.service
test -L /etc/systemd/system/rpm-ostree-countme.timer
test "$(readlink /etc/systemd/system/rpm-ostree-countme.timer)" = "/dev/null"
for masked_unit in geoclue.service sshd.service sshd.socket sshd-keygen.target; do
    test -L "/etc/systemd/system/${masked_unit}"
    test "$(readlink "/etc/systemd/system/${masked_unit}")" = "/dev/null"
done
! grep -RIn '^countme=1$' /etc/yum.repos.d /usr/etc/yum.repos.d >/dev/null 2>&1
test -f /usr/lib/sysctl.d/55-nocblue-hardening.conf
grep -q '^kernel.dmesg_restrict = 1$' /usr/lib/sysctl.d/55-nocblue-hardening.conf
grep -q '^kernel.unprivileged_bpf_disabled = 1$' /usr/lib/sysctl.d/55-nocblue-hardening.conf
grep -q '^net.ipv6.conf.default.use_tempaddr = 2$' /usr/lib/sysctl.d/55-nocblue-hardening.conf
grep -q '^LLMNR=false$' /etc/systemd/resolved.conf.d/10-disable-llmnr.conf
grep -q '^ipv6.ip6-privacy=2$' /usr/lib/NetworkManager/conf.d/40-nocblue-privacy.conf
grep -q '^DumpCore=no$' /etc/systemd/system.conf.d/60-disable-coredump.conf
grep -q '^DumpCore=no$' /etc/systemd/user.conf.d/60-disable-coredump.conf
grep -q 'hard core 0' /etc/security/limits.d/60-disable-coredump.conf
test -f /usr/lib/systemd/system/nocblue-brew-formulae.service
test -f /usr/lib/systemd/system/nocblue-hardened-malloc-flatpaks.service
test -f /usr/lib/systemd/system/nocblue-session-defaults.service
test -f /usr/lib/systemd/user/nocblue-adwsteamgtk.service
test -f /usr/lib/systemd/user/nocblue-adwsteamgtk.timer
test -f /usr/lib/systemd/user/nocblue-flatpak-icon-fixes.service
grep -q 'user-defaults.v5.done' /usr/lib/systemd/user/nocblue-user-defaults.service
test -x /usr/bin/nocblue-apply-adwsteamgtk
grep -q 'flatpak run --system io.github.Foldex.AdwSteamGtk' /usr/bin/nocblue-apply-adwsteamgtk
! grep -q 'flatpak install --user' /usr/bin/nocblue-apply-adwsteamgtk
test -x /usr/bin/nocblue-fix-flatpak-icons
test -x /usr/bin/nocblue-hardened-malloc-run
test -x /usr/bin/nocblue-apply-hardened-malloc
grep -q '/var/lib/nocblue/hardened-malloc/libhardened_malloc.so' /usr/bin/nocblue-apply-hardened-malloc
! grep -q -- '--filesystem=host-os:ro' /usr/bin/nocblue-apply-hardened-malloc
grep -q '^Exec=/usr/bin/nocblue-hardened-malloc-run /usr/bin/trivalent' /usr/share/applications/trivalent.desktop
test -f /usr/share/nocblue/manifests/hardened-malloc-flatpaks.txt
grep -q '^org.gnome.Loupe$' /usr/share/nocblue/manifests/hardened-malloc-flatpaks.txt
grep -q '^org.gnome.Papers$' /usr/share/nocblue/manifests/hardened-malloc-flatpaks.txt
grep -q '^org.gnome.Showtime$' /usr/share/nocblue/manifests/hardened-malloc-flatpaks.txt
grep -q '^io.github.diegopvlk.Cine$' /usr/share/nocblue/manifests/hardened-malloc-flatpaks.txt
! grep -RIn 'LD_PRELOAD=.*hardened_malloc' /etc/profile.d /usr/lib/environment.d /etc/security/pam_env.conf >/dev/null 2>&1
test -f /usr/share/wayland-sessions/niri.desktop
grep -q '^Session=niri$' /etc/accountsservice/user-templates/standard
grep -q '^Session=niri$' /etc/accountsservice/user-templates/administrator
test -f /usr/share/backgrounds/nocblue/green-eyes.png
test -f /usr/share/nocblue/defaults/noctalia/cache/wallpapers.json
grep -q '/usr/share/backgrounds/nocblue/green-eyes.png' /usr/share/nocblue/defaults/noctalia/settings.json
grep -q '/usr/share/backgrounds/nocblue/green-eyes.png' /usr/share/nocblue/defaults/noctalia/cache/wallpapers.json
test -f /usr/share/nocblue/manifests/brew-formulae.txt
ujust --list | grep -q 'enroll-secure-boot-key'
ujust --list | grep -q 'toggle-updates'
ujust --list | grep -q 'clean-system'
grep -q '^gh$' /usr/share/nocblue/manifests/brew-formulae.txt
grep -q '^adb$' /usr/share/nocblue/manifests/brew-formulae.txt
grep -q '^openjdk@17$' /usr/share/nocblue/manifests/brew-formulae.txt
test -f /usr/share/nocblue/defaults/fish/config.fish
grep -q 'set -g fish_greeting' /usr/share/nocblue/defaults/fish/config.fish
grep -q '^x-scheme-handler/http[[:space:]]*io.github.alyraffauf.Switchyard.desktop$' /usr/share/nocblue/defaults/xdg/mime-defaults.tsv
grep -q '^text/html[[:space:]]*io.github.alyraffauf.Switchyard.desktop$' /usr/share/nocblue/defaults/xdg/mime-defaults.tsv
grep -q '^favorite_browser = '\''librewolf.desktop'\''$' /usr/share/nocblue/defaults/switchyard/config.toml
test -f /usr/share/nocblue/defaults/nautilus/copy_location.py
test -f /usr/share/nocblue/defaults/nautilus/folder_icon.py
test -f /usr/share/nocblue/defaults/nautilus/new_file.py
python3 - <<'PY'
from pathlib import Path

for path in Path("/usr/share/nocblue/defaults/nautilus").glob("*.py"):
    compile(path.read_text(encoding="utf-8"), str(path), "exec")
PY

test -f /etc/firewalld/services/kdeconnect.xml
test -f /usr/lib/systemd/system/input-remapper.service
test -f /usr/lib/systemd/system/me.proton.vpn.split_tunneling.service
grep -q '1714-1764' /etc/firewalld/services/kdeconnect.xml

test -f /usr/share/nocblue/manifests/flatpaks.txt
test -f /usr/share/nocblue/manifests/flatpak-icon-fixes.txt
grep -q '^com.github.marhkb.Pods$' /usr/share/nocblue/manifests/flatpak-icon-fixes.txt
grep -q '^io.gitlab.news_flash.NewsFlash$' /usr/share/nocblue/manifests/flatpak-icon-fixes.txt
grep -q '^org.gnome.Loupe$' /usr/share/nocblue/manifests/flatpaks.txt
grep -q '^org.gnome.Showtime$' /usr/share/nocblue/manifests/flatpaks.txt
grep -q '^io.github.Foldex.AdwSteamGtk$' /usr/share/nocblue/manifests/flatpaks.txt
grep -q '^org.signal.Signal$' /usr/share/nocblue/manifests/flatpaks.txt
grep -q '^com.github.zocker_160.SyncThingy$' /usr/share/nocblue/manifests/flatpaks.txt
grep -q '^com.valvesoftware.Steam$' /usr/share/nocblue/manifests/flatpaks.txt
grep -q '^net.davidotek.pupgui2$' /usr/share/nocblue/manifests/flatpaks.txt
grep -q '^net.lutris.Lutris$' /usr/share/nocblue/manifests/flatpaks.txt
grep -q '^org.freedesktop.Platform.VulkanLayer.MangoHud//' /usr/share/nocblue/manifests/flatpaks.txt
grep -q '^org.freedesktop.Platform.VulkanLayer.gamescope//' /usr/share/nocblue/manifests/flatpaks.txt

if command -v niri >/dev/null 2>&1; then
    niri validate -c /etc/xdg/niri/config.kdl
fi
