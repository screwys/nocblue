#!/usr/bin/env bash
set -euo pipefail

fedora_version="$(rpm -E %fedora)"
test "${fedora_version}" = "44"

is_hardened=false
if grep -q '^VARIANT_ID=nocblue-hardened$' /usr/lib/os-release; then
    is_hardened=true
fi

rpm -q kernel kernel-core kernel-modules-core >/dev/null
! rpm -q kernel-cachyos kernel-cachyos-devel-matched cachyos-settings >/dev/null 2>&1
! find /usr/lib/modules -maxdepth 1 -mindepth 1 -type d -name '*cachyos*' | grep -q .

for cmd in niri qs fish fastfetch wl-copy wl-paste wf-recorder wl-screenrec wlsunset kdeconnectd firefox librewolf mullvad-browser trivalent brave-origin-beta helium zed magick tesseract ujust njust loupe showtime bwrap xdg-dbus-proxy patch pywalfox nm-connection-editor nmtui java javac go cargo rustc gcc g++ make cmake pkg-config curl unzip 7z docker podman podman-compose sddm sddm-greeter-qt6 openrazer-daemon polychromatic-controller polychromatic-cli nocblue-sync-sddm-wallpaper nocblue-setup-android-sdk nocblue-ocr-japanese nocblue-check-secureblue-base; do
    command -v "${cmd}" >/dev/null 2>&1 || {
        printf 'missing expected command: %s\n' "${cmd}" >&2
        exit 1
    }
done

if [[ -d /etc/xdg/quickshell/noctalia-shell || -d /usr/share/quickshell/noctalia-shell || -d /usr/share/noctalia-shell ]]; then
    :
else
    printf 'missing noctalia-shell runtime\n' >&2
    exit 1
fi

rpm -q gh jq nodejs24-bin nodejs24-npm-bin pnpm ripgrep fd-find bat eza fzf tree curl wget2-wget unzip 7zip yq yt-dlp direnv neovim socat zoxide btop duf du-dust hyperfine tokei ShellCheck shfmt uv android-tools java-latest-openjdk-devel golang rust cargo gcc gcc-c++ make cmake pkgconf-pkg-config openssl-devel brave-origin-beta helium-bin mullvad-browser ghostty loupe showtime input-remapper openrazer-daemon python3-openrazer polychromatic openrazer-kmod-common kmod-openrazer ImageMagick tesseract tesseract-langpack-eng tesseract-langpack-jpn tesseract-langpack-jpn_vert adwaita-cursor-theme google-noto-sans-cjk-fonts radicale3 radicale3-selinux nginx protonvpn-beta-release proton-vpn-gnome-desktop hardened_malloc no_rlimit_as podman podman-docker podman-compose nm-connection-editor NetworkManager-tui NetworkManager-wifi network-manager-applet sddm sddm-x11 xorg-x11-server-Xorg qt6-qt5compat qt6-qtsvg kf6-kitemmodels zram-generator wlsunset >/dev/null
test -f /usr/lib64/qt6/qml/org/kde/kitemmodels/qmldir
! rpm -qa --qf '%{NAME}\n' | grep -qx 'openrazer-kernel-modules-dkms'
rpm -q pipx >/dev/null
rpm -q shim-x64 grub2-efi-x64-cdboot grub2-tools >/dev/null
rpm -q anaconda anaconda-core anaconda-dracut anaconda-install-env-deps dracut-config-generic dracut-network net-tools squashfs-tools lorax-templates-generic biosdevname prefixdevname python3-mako >/dev/null
test -f /boot/efi/EFI/fedora/shimx64.efi
test -f /boot/efi/EFI/fedora/mmx64.efi
test -f /boot/efi/EFI/fedora/gcdx64.efi
test -f /usr/share/grub/unicode.pf2
test -x /usr/libexec/anaconda/run-anaconda
test -f /usr/share/lorax/templates.d/99-generic/runtime-postinstall.tmpl
test -d /mnt
test ! -L /mnt
test -d /var/mnt
test ! -L /var/mnt
test -d /var/tmp
test ! -L /var/tmp
test "$(stat -c %a /var/tmp)" = "1777"
test -f /usr/lib/dracut/dracut.conf.d/99-nocblue-installer-tmpdir.conf
grep -qx 'tmpdir="/tmp"' /usr/lib/dracut/dracut.conf.d/99-nocblue-installer-tmpdir.conf
test -f /usr/lib/tmpfiles.d/nocblue-installer.conf
grep -qx 'd /var/tmp 1777 root root -' /usr/lib/tmpfiles.d/nocblue-installer.conf
python3 - <<'PY'
import mako.template
PY
! rpm -q protonvpn-stable-release >/dev/null 2>&1
for pkg in ptyxis gnome-terminal gnome-terminal-nautilus gnome-console kgx lxqt-policykit torbrowser-launcher temurin-17-jdk; do
    ! rpm -q "${pkg}" >/dev/null 2>&1 || {
        printf 'removed package is still installed: %s\n' "${pkg}" >&2
        exit 1
    }
done
! grep -RIn 'lxqt-policykit-agent' /etc/xdg/niri /usr/share/nocblue/defaults/niri >/dev/null 2>&1

test -x /usr/bin/ghostty
test ! -e /usr/local/bin/ghostty
test -x /usr/bin/pywalfox
test ! -e /usr/local/bin/pywalfox
test -x /usr/libexec/pywalfox-native-messaging-host
test -f /usr/lib/mozilla/native-messaging-hosts/pywalfox.json
test -f /usr/lib64/mozilla/native-messaging-hosts/pywalfox.json
test -f /usr/share/mozilla/native-messaging-hosts/pywalfox.json
test -f /usr/share/librewolf/native-messaging-hosts/pywalfox.json
test -f /usr/lib64/librewolf/native-messaging-hosts/pywalfox.json
test -f /usr/lib/librewolf/native-messaging-hosts/pywalfox.json
test -x /usr/libexec/pywalfox-native-messaging-host-proxy
test -f /usr/lib64/firefox/distribution/policies.json
test -f /usr/share/librewolf/distribution/policies.json
test -f /usr/lib64/librewolf/distribution/policies.json
test -f /usr/lib/librewolf/distribution/policies.json
test -f /etc/trivalent/policies/managed/nocblue-search.json
test -f /etc/trivalent/policies/managed/nocblue-extensions.json
test -f /etc/trivalent/master_preferences
test -f /etc/trivalent/trivalent.conf.d/20-nocblue.conf
test -f /etc/brave/policies/managed/nocblue-extensions.json
test -f /etc/chromium/policies/managed/nocblue-extensions.json
test -f /etc/helium/policies/managed/nocblue-extensions.json
