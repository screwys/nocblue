    "firefox@tampermonkey.net": "tampermonkey",
}

firefox_settings = firefox["policies"]["ExtensionSettings"]
librewolf_settings = librewolf["policies"]["ExtensionSettings"]
assert librewolf_lib64 == librewolf
assert librewolf_lib == librewolf
for extension_id, slug in shared.items():
    for settings in (firefox_settings, librewolf_settings):
        policy = settings[extension_id]
        assert policy["installation_mode"] == "normal_installed"
        assert policy["private_browsing"] is True
        assert policy["install_url"] == f"https://addons.mozilla.org/firefox/downloads/latest/{slug}/latest.xpi"

ublock = firefox_settings["uBlock0@raymondhill.net"]
assert ublock["installation_mode"] == "normal_installed"
assert ublock["install_url"] == "https://addons.mozilla.org/firefox/downloads/latest/ublock-origin/latest.xpi"
assert firefox["policies"]["DisableFirefoxStudies"] is True
assert firefox["policies"]["DisablePocket"] is True
assert firefox["policies"]["DisableTelemetry"] is True
assert firefox["policies"]["DontCheckDefaultBrowser"] is True
assert firefox["policies"]["ManualAppUpdateOnly"] is True
assert firefox["policies"]["OfferToSaveLoginsDefault"] is False
assert firefox["policies"]["OverrideFirstRunPage"] == ""
assert firefox["policies"]["OverridePostUpdatePage"] == ""
assert firefox["policies"]["SearchEngines"]["Default"] == "DuckDuckGo"
assert firefox["policies"]["SearchEngines"]["PreventInstalls"] is True
assert firefox["policies"]["SearchSuggestEnabled"] is False
assert firefox["policies"]["SkipTermsOfUse"] is True
assert firefox["policies"]["FirefoxSuggest"]["WebSuggestions"] is False
assert firefox["policies"]["FirefoxSuggest"]["SponsoredSuggestions"] is False
assert firefox["policies"]["Homepage"] == {
    "Locked": False,
    "StartPage": "none",
    "URL": "about:blank",
}
assert librewolf["policies"]["Homepage"] == firefox["policies"]["Homepage"]
