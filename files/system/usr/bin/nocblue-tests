python3 - <<'PY'
import json
from pathlib import Path

for path in Path("/usr/share/nocblue/defaults/nautilus").glob("*.py"):
    compile(path.read_text(encoding="utf-8"), str(path), "exec")

settings = json.loads(Path("/usr/share/nocblue/defaults/noctalia/settings.json").read_text(encoding="utf-8"))
assert settings["colorSchemes"]["predefinedScheme"] == "Catppuccin Mocha Red"
assert settings["hooks"]["enabled"] is True
assert settings["hooks"]["wallpaperChange"] == "nocblue-sync-sddm-wallpaper"
assert {"enabled": True, "id": "sddm"} in settings["templates"]["activeTemplates"]
assert settings["templates"]["enableUserTheming"] is True
assert settings["nightLight"]["autoSchedule"] is False
assert "firefox" not in settings["appLauncher"]["pinnedApps"]
assert "firefox" not in settings["dock"]["pinnedApps"]
assert "torbrowser" not in settings["appLauncher"]["pinnedApps"]
assert "torbrowser" not in settings["dock"]["pinnedApps"]
assert "org.mozilla.firefox" in settings["appLauncher"]["pinnedApps"]
assert "org.mozilla.firefox" in settings["dock"]["pinnedApps"]
assert "com.brave.Origin.beta" in settings["appLauncher"]["pinnedApps"]
assert "helium" in settings["appLauncher"]["pinnedApps"]
bar = settings["bar"]
assert bar["monitors"] == []
assert bar["screenOverrides"] == []
assert [item["id"] for item in bar["widgets"]["left"]] == [
    "Launcher",
    "Clock",
    "plugin:timer",
    "plugin:weather-indicator",
    "NotificationHistory",
    "Volume",
    "plugin:todo",
    "plugin:clipper",
    "plugin:noctalia-calculator",
    "Network",
]
assert [item["id"] for item in bar["widgets"]["right"]] == [
    "MediaMini",
    "Tray",
    "SystemMonitor",
]
assert all(item["id"] != "VPN" for section in bar["widgets"].values() for item in section)
plugins = json.loads(Path("/usr/share/nocblue/defaults/noctalia/plugins.json").read_text(encoding="utf-8"))
assert plugins["states"]["weather-indicator"]["enabled"] is True
for plugin in [
    "clipper",
    "file-search",
    "kaomoji-provider",
    "niri-animation-picker",
    "niri-overview-launcher",
    "noctalia-calculator",
    "notes-scratchpad",
    "polkit-agent",
    "pomodoro",
    "screen-recorder",
    "screen-toolkit",
    "timer",
    "todo",
    "weather-indicator",
]:
    assert Path(f"/usr/share/nocblue/defaults/noctalia/plugins/{plugin}/manifest.json").is_file()
PY

