import json
from pathlib import Path

firefox = json.loads(Path("/usr/lib64/firefox/distribution/policies.json").read_text(encoding="utf-8"))
librewolf = json.loads(Path("/usr/share/librewolf/distribution/policies.json").read_text(encoding="utf-8"))
