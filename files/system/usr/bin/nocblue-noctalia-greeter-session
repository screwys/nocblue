#!/usr/bin/bash
set -euo pipefail

read_xorg_keyboard_option() {
    local option="${1}"
    local path=/etc/X11/xorg.conf.d/00-keyboard.conf

    [[ -r "${path}" ]] || return 1
    awk -v option="${option}" '
        $1 == "Option" && $2 == "\"" option "\"" {
            value = $0
            sub(/^[[:space:]]*Option[[:space:]]+"[^"]+"[[:space:]]+"/, "", value)
            sub(/".*$/, "", value)
            print value
            exit
        }
    ' "${path}"
}

read_vconsole_value() {
    local key="${1}"
    local path=/etc/vconsole.conf

    [[ -r "${path}" ]] || return 1
    awk -F= -v key="${key}" '
        $1 == key {
            value = substr($0, index($0, "=") + 1)
            gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)
            if (value ~ /^".*"$/) {
                value = substr(value, 2, length(value) - 2)
            }
            print value
            exit
        }
    ' "${path}"
}

set_xkb_default() {
    local env_name="${1}"
    local xorg_option="${2}"
    local vconsole_key="${3}"
    local value=""

    [[ -z "${!env_name:-}" ]] || return 0
    value="$(read_xorg_keyboard_option "${xorg_option}" || true)"
    if [[ -z "${value}" ]]; then
        value="$(read_vconsole_value "${vconsole_key}" || true)"
    fi
    if [[ -n "${value}" ]]; then
        export "${env_name}=${value}"
    fi
}

set_xkb_default XKB_DEFAULT_LAYOUT XkbLayout XKBLAYOUT
set_xkb_default XKB_DEFAULT_VARIANT XkbVariant XKBVARIANT
set_xkb_default XKB_DEFAULT_OPTIONS XkbOptions XKBOPTIONS
set_xkb_default XKB_DEFAULT_MODEL XkbModel XKBMODEL

exec /usr/bin/noctalia-greeter-session "$@"
