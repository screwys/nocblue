#!/usr/bin/env bash
set -euo pipefail

manifest="${1:-/usr/share/nocblue/manifests/hardened-malloc-flatpaks.txt}"

best_microarch() {
    /usr/lib64/ld-linux-x86-64.so.2 --help 2>/dev/null |
        awk '/x86-64-v[0-9].*supported, searched/ { print $1; exit }'
}

find_hardened_malloc() {
    local uarch
    uarch="$(best_microarch || true)"

    if [[ -n "${uarch}" && -r "/usr/lib64/glibc-hwcaps/${uarch}/libhardened_malloc.so" ]]; then
        printf '/usr/lib64/glibc-hwcaps/%s/libhardened_malloc.so\n' "${uarch}"
        return 0
    fi

    if [[ -r /usr/lib64/libhardened_malloc.so ]]; then
        printf '/usr/lib64/libhardened_malloc.so\n'
        return 0
    fi

    printf 'hardened_malloc library not found\n' >&2
    return 1
}

if ! command -v flatpak >/dev/null 2>&1; then
    printf 'flatpak is not installed\n' >&2
    exit 1
fi

host_lib="$(find_hardened_malloc)"
flatpak_lib="/var/lib/nocblue/hardened-malloc/libhardened_malloc.so"
install -D -m 0644 "${host_lib}" "${flatpak_lib}"

while IFS= read -r app_id; do
    [[ -z "${app_id}" || "${app_id}" =~ ^[[:space:]]*# ]] && continue
    flatpak override --system --filesystem="${flatpak_lib}:ro" --env="LD_PRELOAD=${flatpak_lib}" "${app_id}"
done < "${manifest}"
