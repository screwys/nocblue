#!/usr/bin/env bash
set -euo pipefail

stamp_dir="/var/lib/nocblue"
install -d -m 0755 "${stamp_dir}"

brew_bin="/home/linuxbrew/.linuxbrew/bin/brew"
if [[ ! -x "${brew_bin}" && -x "/var/home/linuxbrew/.linuxbrew/bin/brew" ]]; then
    brew_bin="/var/home/linuxbrew/.linuxbrew/bin/brew"
fi

if [[ ! -x "${brew_bin}" && -f /usr/lib/systemd/system/brew-setup.service ]]; then
    systemctl start brew-setup.service || true
fi

for _ in $(seq 1 60); do
    [[ -x "${brew_bin}" ]] && break
    sleep 2
done

if [[ ! -x "${brew_bin}" ]]; then
    printf 'Homebrew is not ready; leaving formula install for the next boot\n' >&2
    exit 1
fi

run_brew() {
    if id linuxbrew >/dev/null 2>&1; then
        runuser -u linuxbrew -- "${brew_bin}" "$@"
    else
        "${brew_bin}" "$@"
    fi
}

run_brew analytics off || true
run_brew update || true

while IFS= read -r formula; do
    [[ -z "${formula}" || "${formula}" =~ ^[[:space:]]*# ]] && continue
    run_brew install "${formula}" || run_brew upgrade "${formula}" || true
done < /usr/share/nocblue/manifests/brew-formulae.txt

run_brew upgrade || true
touch "${stamp_dir}/brew-formulae.stamp"
