#!/usr/bin/env bash
set -euo pipefail

if [[ "$(id -u)" -eq 0 ]]; then
    printf 'nocblue-sync-icon-theme must run as the target user\n' >&2
    exit 1
fi

state_dir="${HOME}/.local/state/nocblue"
target="${HOME}/.local/share/icons/candy-icons"
stamp="${state_dir}/candy-icons.source"
managed_stamp="${state_dir}/candy-icons.managed"
source=""

for candidate in /usr/share/icons/candy-icons /usr/share/icons/Candy; do
    if [[ -d "${candidate}" ]]; then
        source="${candidate}"
        break
    fi
done

if [[ -z "${source}" ]]; then
    exit 0
fi

source_id="$(stat -Lc '%n:%Y:%s' "${source}/index.theme")"
if [[ -f "${source}/nocblue-source-ref" ]]; then
    source_id="${source_id}:$(cat "${source}/nocblue-source-ref")"
fi

vesktop_app_icon_source=""
for candidate in \
    "${HOME}/.local/share/flatpak/exports/share/icons/hicolor/scalable/apps/dev.vencord.Vesktop.svg" \
    "/var/lib/flatpak/exports/share/icons/hicolor/scalable/apps/dev.vencord.Vesktop.svg" \
    "${HOME}/.local/share/flatpak/app/dev.vencord.Vesktop/current/active/export/share/icons/hicolor/scalable/apps/dev.vencord.Vesktop.svg" \
    "/var/lib/flatpak/app/dev.vencord.Vesktop/current/active/export/share/icons/hicolor/scalable/apps/dev.vencord.Vesktop.svg" \
    "${HOME}/.local/share/flatpak/app/dev.vencord.Vesktop/current/active/files/share/icons/hicolor/scalable/apps/dev.vencord.Vesktop.svg" \
    "/var/lib/flatpak/app/dev.vencord.Vesktop/current/active/files/share/icons/hicolor/scalable/apps/dev.vencord.Vesktop.svg"; do
    if [[ -f "${candidate}" || -L "${candidate}" ]]; then
        vesktop_app_icon_source="${candidate}"
        break
    fi
done

vesktop_icon_source=""
for candidate in \
    "${HOME}/.local/share/flatpak/app/dev.vencord.Vesktop/current/active/files/bin/vesktop/usr/share/icons/hicolor/scalable/vesktop.svg" \
    "/var/lib/flatpak/app/dev.vencord.Vesktop/current/active/files/bin/vesktop/usr/share/icons/hicolor/scalable/vesktop.svg"; do
    if [[ -f "${candidate}" || -L "${candidate}" ]]; then
        vesktop_icon_source="${candidate}"
        break
    fi
done

source_id="${source_id}:vesktop-icon-overrides-v1"
for override_source in "${vesktop_app_icon_source}" "${vesktop_icon_source}"; do
    if [[ -n "${override_source}" ]]; then
        source_id="${source_id}:$(stat -Lc '%n:%Y:%s' "${override_source}")"
    else
        source_id="${source_id}:none"
    fi
done

mkdir -p "${state_dir}" "${HOME}/.local/share/icons"

if [[ -e "${target}" && ! -e "${managed_stamp}" ]]; then
    exit 0
fi

if [[ -e "${target}" && -f "${stamp}" ]] && grep -qxF "${source_id}" "${stamp}"; then
    exit 0
fi

mkdir -p "${target}"
cp -aL "${source}/." "${target}/"
if [[ -n "${vesktop_app_icon_source}" ]]; then
    install -D -m 0644 "${vesktop_app_icon_source}" "${target}/apps/scalable/dev.vencord.Vesktop.svg"
else
    rm -f "${target}/apps/scalable/dev.vencord.Vesktop.svg"
fi
if [[ -n "${vesktop_icon_source}" ]]; then
    install -D -m 0644 "${vesktop_icon_source}" "${target}/apps/scalable/vesktop.svg"
elif [[ -n "${vesktop_app_icon_source}" ]]; then
    install -D -m 0644 "${vesktop_app_icon_source}" "${target}/apps/scalable/vesktop.svg"
else
    rm -f "${target}/apps/scalable/vesktop.svg"
fi
printf '%s\n' "${source_id}" > "${stamp}"
touch "${managed_stamp}"
