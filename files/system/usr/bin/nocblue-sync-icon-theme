#!/usr/bin/env bash
set -euo pipefail

if [[ "$(id -u)" -eq 0 ]]; then
    printf 'nocblue-sync-icon-theme must run as the target user\n' >&2
    exit 1
fi

state_dir="${HOME}/.local/state/nocblue"
target="${HOME}/.local/share/icons/candy-icons"
stamp="${state_dir}/candy-icons.source"
managed_stamp="${state_dir}/candy-icons.managed"
source=""

for candidate in /usr/share/icons/candy-icons /usr/share/icons/Candy; do
    if [[ -d "${candidate}" ]]; then
        source="${candidate}"
        break
    fi
done

if [[ -z "${source}" ]]; then
    exit 0
fi

if command -v rpm >/dev/null 2>&1 && rpm -q candy-icon-theme >/dev/null 2>&1; then
    source_id="$(rpm -q candy-icon-theme)"
else
    source_id="$(stat -Lc '%n:%Y:%s' "${source}/index.theme")"
fi

mkdir -p "${state_dir}" "${HOME}/.local/share/icons"

if [[ -e "${target}" && ! -e "${managed_stamp}" ]]; then
    exit 0
fi

if [[ -e "${target}" && -f "${stamp}" ]] && grep -qxF "${source_id}" "${stamp}"; then
    exit 0
fi

tmp="$(mktemp -d "${HOME}/.local/share/icons/.candy-icons.XXXXXX")"
cleanup() {
    rm -rf "${tmp}"
}
trap cleanup EXIT

cp -aL "${source}/." "${tmp}/"
rm -rf "${target}"
mv "${tmp}" "${target}"
trap - EXIT
printf '%s\n' "${source_id}" > "${stamp}"
touch "${managed_stamp}"
