#!/usr/bin/env bash
set -euo pipefail

payload="${NOCBLUE_NIX_PORTABLE_PAYLOAD:-/usr/libexec/nocblue/nix-portable/nix-portable}"
proot_payload="${NOCBLUE_NIX_PORTABLE_PROOT:-/usr/libexec/nocblue/nix-portable/proot}"
post_build_hook="${NOCBLUE_NIX_PORTABLE_POST_BUILD_HOOK:-/usr/libexec/nocblue/nix-portable/clean-build-home}"
profile_sync="${NOCBLUE_NIX_PROFILE_SYNC:-/usr/bin/nix-profile-sync}"

clean_nix_portable_build_home() {
    local emptyroot="${NP_LOCATION}/.nix-portable/emptyroot"
    local build_home="${emptyroot}/homeless-shelter"

    if [[ -z "${NP_LOCATION}" || "${NP_LOCATION}" != /* || "${NP_LOCATION}" == "/" || "${emptyroot}" == "/" || "${build_home}" == "/" ]]; then
        printf 'nix: refusing to clean invalid nix-portable build home: %s\n' "${build_home}" >&2
        exit 1
    fi

    rm -rf -- "${build_home}"
}

should_sync_nix_profile() {
    [[ "${1:-}" == "profile" ]] || return 1

    case "${2:-}" in
        install | remove | rollback | upgrade | wipe-history)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

if [[ ! -x "${payload}" ]]; then
    cat >&2 <<'MSG'
nix-portable is not installed in this nocblue image.
Expected executable: /usr/libexec/nocblue/nix-portable/nix-portable
MSG
    exit 127
fi

if [[ ! -x "${proot_payload}" ]]; then
    cat >&2 <<MSG
nocblue patched proot is not installed.
Expected executable: ${proot_payload}
MSG
    exit 127
fi

if [[ ! -x "${post_build_hook}" ]]; then
    cat >&2 <<MSG
nocblue nix-portable build-home cleanup hook is not installed.
Expected executable: ${post_build_hook}
MSG
    exit 127
fi

if [[ -z "${HOME:-}" ]]; then
    home_from_passwd="$(getent passwd "$(id -u)" | cut -d: -f6 || true)"
    if [[ -z "${home_from_passwd}" ]]; then
        printf 'nix: HOME is not set and no passwd home exists for uid %s\n' "$(id -u)" >&2
        exit 1
    fi
    export HOME="${home_from_passwd}"
fi

export NP_LOCATION="${NP_LOCATION:-${HOME}}"
export NP_RUNTIME=proot
export NP_PROOT="${proot_payload}"
clean_nix_portable_build_home

unset NIX_REMOTE
unset NIX_PROFILES
unset NIX_USER_CONF_FILES
unset NIX_PATH
unset NIX_SSL_CERT_FILE
unset LD_PRELOAD
unset LD_AUDIT

if should_sync_nix_profile "$@"; then
    set +e
    "${payload}" nix --option post-build-hook "${post_build_hook}" "$@"
    status=$?
    set -e

    if [[ "${status}" -eq 0 ]]; then
        if [[ -x "${profile_sync}" ]]; then
            "${profile_sync}" || printf 'nix: warning: failed to sync nix profile shims\n' >&2
        else
            printf 'nix: warning: nix profile shim sync helper is not executable: %s\n' "${profile_sync}" >&2
        fi
    fi

    exit "${status}"
fi

# Keep this shell as the parent process. Callers such as retry helpers may use
# Bash process substitutions for logging; execing into PRoot can leave those
# helper processes parented under PRoot after Nix exits.
"${payload}" nix --option post-build-hook "${post_build_hook}" "$@"
exit "$?"
