#!/usr/bin/env bash
set -euo pipefail

if [[ "$(id -u)" -eq 0 ]]; then
    printf 'nocblue-apply-user-defaults must run as the target user\n' >&2
    exit 1
fi

state_dir="${HOME}/.local/state/nocblue"
mkdir -p "${state_dir}"
version_stamp="${state_dir}/user-defaults.v25.done"
defaults_dir="${NOCBLUE_DEFAULTS_DIR:-/usr/share/nocblue/defaults}"

copy_if_missing() {
    local src="$1"
    local dst="$2"
    if [[ ! -e "${dst}" ]]; then
        install -D -m 0644 "${src}" "${dst}"
    fi
}

copy_if_missing_or_legacy() {
    local src="$1"
    local dst="$2"
    local legacy_check="$3"

    if [[ ! -e "${dst}" ]] || "${legacy_check}" "${dst}"; then
        install -D -m 0644 "${src}" "${dst}"
    fi
}

legacy_ghostty_config() {
    grep -qx 'font-family = JetBrainsMono Nerd Font' "$1"
}

ensure_ghostty_keep_warm() {
    local config="${HOME}/.config/ghostty/config"
    [[ -f "${config}" ]] || return 0

    python3 - "${config}" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
lines = path.read_text(encoding="utf-8").splitlines()

def has_key(name: str) -> bool:
    for line in lines:
        stripped = line.strip()
        if not stripped or stripped.startswith("#") or "=" not in stripped:
            continue
        if stripped.split("=", 1)[0].strip() == name:
            return True
    return False

wanted = [
    ("quit-after-last-window-closed", "true"),
    ("quit-after-last-window-closed-delay", "5m"),
]
missing = [(key, value) for key, value in wanted if not has_key(key)]
if not missing:
    raise SystemExit(0)

if lines and lines[-1].strip():
    lines.append("")
lines.append("# Startup")
for key, value in missing:
    lines.append(f"{key} = {value}")

path.write_text("\n".join(lines) + "\n", encoding="utf-8")
PY
}

ensure_ghostty_user_service() {
    local stamp="${state_dir}/ghostty-service.defaulted"
    local enabled_state

    [[ -f "${stamp}" ]] && return 0
    command -v systemctl >/dev/null 2>&1 || return 0

    enabled_state="$(systemctl --user is-enabled app-com.mitchellh.ghostty.service 2>/dev/null || true)"
    case "${enabled_state}" in
        enabled | masked)
            : >"${stamp}"
            return 0
            ;;
    esac

    if systemctl --user enable app-com.mitchellh.ghostty.service >/dev/null 2>&1; then
        : >"${stamp}"
    fi
}

legacy_zed_settings() {
    python3 - "$1" <<'PY'
import json
import sys

try:
    data = json.load(open(sys.argv[1], encoding="utf-8"))
except Exception:
    raise SystemExit(1)

theme = data.get("theme", {})
is_previous_public_default = (
    theme.get("mode") == "system"
    and theme.get("light") == "One Light"
    and theme.get("dark") == "Noctalia"
    and data.get("buffer_font_family") == "JetBrainsMono Nerd Font"
    and data.get("ui_font_family") == "Inter"
)
raise SystemExit(0 if is_previous_public_default else 1)
PY
}

ensure_zed_settings() {
    local settings_path="${HOME}/.config/zed/settings.json"
    install -d -m 0755 "$(dirname "${settings_path}")"

    if [[ ! -e "${settings_path}" ]]; then
        install -D -m 0644 "${defaults_dir}/zed/settings.json" "${settings_path}"
        return 0
    fi

    python3 - "${settings_path}" <<'PY'
import json
import re
import sys
from pathlib import Path

path = Path(sys.argv[1])
text = path.read_text(encoding="utf-8")

def strip_jsonc(src: str) -> str:
    out = []
    i = 0
    in_string = False
    escape = False
    while i < len(src):
        ch = src[i]
        nxt = src[i + 1] if i + 1 < len(src) else ""
        if in_string:
            out.append(ch)
            if escape:
                escape = False
            elif ch == "\\":
                escape = True
            elif ch == '"':
                in_string = False
            i += 1
            continue
        if ch == '"':
            in_string = True
            out.append(ch)
            i += 1
            continue
        if ch == "/" and nxt == "/":
            i += 2
            while i < len(src) and src[i] not in "\r\n":
                i += 1
            continue
        if ch == "/" and nxt == "*":
            i += 2
            while i + 1 < len(src) and not (src[i] == "*" and src[i + 1] == "/"):
                i += 1
            i += 2
            continue
        out.append(ch)
        i += 1
    cleaned = "".join(out)
    return re.sub(r",\s*([}\]])", r"\1", cleaned)

try:
    data = json.loads(strip_jsonc(text) or "{}")
except Exception:
    raise SystemExit(0)

if not isinstance(data, dict):
    data = {}

stale_themes = (
    {
        "mode": "system",
        "light": "Noctalia Light",
        "dark": "Noctalia Dark",
    },
    {
        "mode": "system",
        "light": "One Light",
        "dark": "Noctalia",
    },
)

if data.get("theme") in stale_themes:
    data.pop("theme", None)
    path.write_text(json.dumps(data, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
PY
}

ensure_gtk_settings() {
    python3 - \
        "${HOME}/.config/gtk-3.0/settings.ini" \
        "${HOME}/.config/gtk-4.0/settings.ini" <<'PY'
from pathlib import Path
import sys

def rewrite_settings(path: Path, wanted: dict[str, str], remove: set[str]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    lines = path.read_text(encoding="utf-8").splitlines() if path.exists() else []

    settings_index = next((idx for idx, line in enumerate(lines) if line.strip() == "[Settings]"), None)
    if settings_index is None:
        lines = ["[Settings]", *lines]
        settings_index = 0

    end = len(lines)
    for idx in range(settings_index + 1, len(lines)):
        stripped = lines[idx].strip()
        if stripped.startswith("[") and stripped.endswith("]"):
            end = idx
            break

    block = lines[settings_index + 1 : end]
    out = []
    seen = set()
    changed = False

    for line in block:
        stripped = line.strip()
        if "=" not in stripped or stripped.startswith("#"):
            out.append(line)
            continue
        key, _ = stripped.split("=", 1)
        if key in remove:
            changed = True
            continue
        if key in wanted:
            replacement = f"{key}={wanted[key]}"
            if line != replacement:
                changed = True
            out.append(replacement)
            seen.add(key)
            continue
        out.append(line)

    for key, value in wanted.items():
        if key not in seen:
            out.append(f"{key}={value}")
            changed = True

    new_lines = lines[: settings_index + 1] + out + lines[end:]
    if changed or new_lines != lines:
        path.write_text("\n".join(new_lines) + "\n", encoding="utf-8")

rewrite_settings(
    Path(sys.argv[1]),
    {
        "gtk-theme-name": "adw-gtk3",
        "gtk-application-prefer-dark-theme": "1",
    },
    {"gtk-icon-theme-name"},
)
rewrite_settings(
    Path(sys.argv[2]),
    {"gtk-theme-name": "adw-gtk3"},
    {"gtk-icon-theme-name", "gtk-application-prefer-dark-theme"},
)
PY
}

legacy_niri_config() {
    grep -q 'spawn-at-startup "waybar"' "$1" && ! grep -q 'nocblue-refresh-portals' "$1"
}

ensure_niri_ghostty_launcher() {
    local config="${HOME}/.config/niri/config.kdl"
    [[ -f "${config}" ]] || return 0

    python3 - "${config}" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
text = path.read_text(encoding="utf-8")
new_text = text
replacements = {
    '    Mod+Return hotkey-overlay-title="Open Terminal: Ghostty" { spawn "/usr/bin/ghostty"; }':
    '    Mod+Return hotkey-overlay-title="Open Terminal: Ghostty" { spawn "/usr/bin/ghostty" "+new-window"; }',
    '    XF86Launch8 hotkey-overlay-title="M5: Open Terminal" { spawn "/usr/bin/ghostty"; }':
    '    XF86Launch8 hotkey-overlay-title="M5: Open Terminal" { spawn "/usr/bin/ghostty" "+new-window"; }',
}
for old, new in replacements.items():
    new_text = new_text.replace(old, new)
if new_text != text:
    path.write_text(new_text, encoding="utf-8")
PY
}

ensure_niri_browser_bridge() {
    local config_dir="${HOME}/.config/niri"
    [[ -d "${config_dir}" ]] || return 0

    python3 - "${config_dir}" <<'PY'
from pathlib import Path
import re
import sys

for path in Path(sys.argv[1]).rglob("*.kdl"):
    text = path.read_text(encoding="utf-8")
    new_text = re.sub(
        r'(?m)^(\s*)BROWSER "flatpak run io\.github\.alyraffauf\.Switchyard"$',
        r'\1BROWSER "/usr/bin/xdg-open"',
        text,
    )
    if new_text != text:
        path.write_text(new_text, encoding="utf-8")
PY
}

ensure_browser_environment() {
    if command -v systemctl >/dev/null 2>&1; then
        systemctl --user set-environment BROWSER=/usr/bin/xdg-open >/dev/null 2>&1 || true
    fi
    if command -v dbus-update-activation-environment >/dev/null 2>&1; then
        dbus-update-activation-environment --systemd BROWSER=/usr/bin/xdg-open >/dev/null 2>&1 || true
    fi
}

stage_user_icon_theme() {
    command -v nocblue-sync-icon-theme >/dev/null 2>&1 || return 0
    nocblue-sync-icon-theme || true
}

apply_user_flatpak_theme_overrides() {
    command -v flatpak >/dev/null 2>&1 || return 0

    flatpak override --user \
        --unset-env=GTK_THEME \
        --filesystem=xdg-config/gtk-3.0:ro \
        --filesystem=xdg-config/gtk-4.0:ro >/dev/null 2>&1 || true

    local app_id
    local themed_apps=(
        com.belmoussaoui.Authenticator
        studio.planetpeanut.Bobby
        io.github.diegopvlk.Cine
        org.gnome.Papers
        org.gnome.Fractal
        io.github.ilya_zlobintsev.LACT
        io.github.radiolamp.mangojuice
        io.missioncenter.MissionCenter
        com.github.marhkb.Pods
        io.github.Foldex.AdwSteamGtk
        it.mijorus.gearlever
    )

    for app_id in "${themed_apps[@]}"; do
        flatpak override --user \
            --unset-env=GTK_THEME \
            --filesystem=xdg-config/gtk-3.0:ro \
            --filesystem=xdg-config/gtk-4.0:ro \
            "${app_id}" >/dev/null 2>&1 || true
    done

    flatpak override --user \
        --unset-env=GTK_THEME \
        --env=SIGNAL_PASSWORD_STORE=gnome-libsecret \
        --filesystem=xdg-config/gtk-3.0:ro \
        --filesystem=xdg-config/gtk-4.0:ro \
        org.signal.Signal >/dev/null 2>&1 || true

    flatpak override --user \
        --unset-env=GTK_THEME \
        --unset-env=LD_PRELOAD \
        --nofilesystem=host-os \
        --filesystem=xdg-config/gtk-3.0:ro \
        --filesystem=xdg-config/gtk-4.0:ro \
        io.github.alyraffauf.Switchyard >/dev/null 2>&1 || true

    flatpak override --user \
        --unset-env=GTK_THEME \
        --unset-env=LD_PRELOAD \
        --env=MANGOHUD=1 \
        --nofilesystem=host-os \
        --filesystem=~/Games \
        --nofilesystem=~/.ssh \
        --nofilesystem=~/.gnupg \
        --nofilesystem=~/.password-store \
        --nofilesystem=~/.local/share/keyrings \
        --nofilesystem=~/.mozilla \
        --nofilesystem=~/.librewolf \
        --nofilesystem=~/.mullvad-browser \
        --nofilesystem=~/.config/BraveSoftware \
        --nofilesystem=~/.config/helium \
        --nofilesystem=~/.config/Helium \
        --nofilesystem=~/.config/trivalent \
        --nofilesystem=~/.cache/mozilla \
        --nofilesystem=~/.cache/librewolf \
        --nofilesystem=~/.cache/mullvad-browser \
        --nofilesystem=~/.cache/BraveSoftware \
        --nofilesystem=~/.cache/helium \
        --nofilesystem=~/.cache/Helium \
        --nofilesystem=~/.cache/trivalent \
        --filesystem=xdg-config/MangoHud:ro \
        --filesystem=xdg-config/gtk-3.0:ro \
        --filesystem=xdg-config/gtk-4.0:ro \
        net.lutris.Lutris >/dev/null 2>&1 || true

    flatpak override --user \
        --unset-env=LD_PRELOAD \
        --env=MANGOHUD=1 \
        --nofilesystem=host-os \
        --filesystem=xdg-config/MangoHud:ro \
        com.valvesoftware.Steam >/dev/null 2>&1 || true
}

ensure_flatpak_desktop_entry() {
    local app_id="$1"
    shift || true

    local src=""
    local candidate
    for candidate in \
        "${HOME}/.local/share/flatpak/exports/share/applications/${app_id}.desktop" \
        "/var/lib/flatpak/exports/share/applications/${app_id}.desktop"; do
        if [[ -f "${candidate}" ]]; then
            src="${candidate}"
            break
        fi
    done

    local dest="${HOME}/.local/share/applications/${app_id}.desktop"

    [[ -n "${src}" ]] || return 0
    install -D -m 0644 "${src}" "${dest}"

    if [[ "$#" -gt 0 ]]; then
        python3 - "$dest" "$app_id" "$@" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
app_id = sys.argv[2]
args = sys.argv[3:]

lines = path.read_text(encoding="utf-8").splitlines()
patched = []
for line in lines:
    if line.startswith("Exec=") and app_id in line:
        for arg in args:
            if arg not in line:
                if " @@u " in line:
                    line = line.replace(" @@u ", f" {arg} @@u ", 1)
                else:
                    line = f"{line} {arg}"
    patched.append(line)

path.write_text("\n".join(patched) + "\n", encoding="utf-8")
PY
    fi
}

ensure_no_preload_flatpak_desktop_entry() {
    local app_id="$1"
    local src=""
    local candidate
    for candidate in \
        "${HOME}/.local/share/flatpak/exports/share/applications/${app_id}.desktop" \
        "/var/lib/flatpak/exports/share/applications/${app_id}.desktop"; do
        if [[ -f "${candidate}" ]]; then
            src="${candidate}"
            break
        fi
    done

    [[ -n "${src}" ]] || return 0

    local dest="${HOME}/.local/share/applications/${app_id}.desktop"
    if [[ -f "${dest}" ]] && ! grep -Eq "flatpak run .*${app_id}" "${dest}"; then
        return 0
    fi

    [[ -f "${dest}" ]] || install -D -m 0644 "${src}" "${dest}"

    python3 - "$dest" "$app_id" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
app_id = sys.argv[2]

lines = path.read_text(encoding="utf-8").splitlines()
patched = []
for line in lines:
    if (
        line.startswith("Exec=")
        and app_id in line
        and "flatpak run" in line
        and "env -u LD_PRELOAD " not in line
    ):
        line = "Exec=env -u LD_PRELOAD " + line.removeprefix("Exec=")
    patched.append(line)

path.write_text("\n".join(patched) + "\n", encoding="utf-8")
PY
}

install_flatpak_desktop_entries() {
    local bazaar_desktop="${HOME}/.local/share/applications/io.github.kolunmi.Bazaar.desktop"
    if [[ -f "${bazaar_desktop}" ]] && grep -q 'flatpak run .*io.github.kolunmi.Bazaar' "${bazaar_desktop}"; then
        rm -f "${bazaar_desktop}"
    fi

    ensure_flatpak_desktop_entry org.signal.Signal --ozone-platform=wayland
    ensure_flatpak_desktop_entry dev.vencord.Vesktop --ozone-platform=wayland
    ensure_no_preload_flatpak_desktop_entry com.valvesoftware.Steam
    ensure_no_preload_flatpak_desktop_entry net.lutris.Lutris

    if command -v update-desktop-database >/dev/null 2>&1; then
        update-desktop-database "${HOME}/.local/share/applications" >/dev/null 2>&1 || true
    fi
}

ensure_protonvpn_visible_launch() {
    local config_path="${HOME}/.config/Proton/VPN/app-config.json"

    python3 - "${config_path}" <<'PY'
from pathlib import Path
import json
import sys

path = Path(sys.argv[1])
path.parent.mkdir(parents=True, exist_ok=True)

if path.exists():
    try:
        config = json.loads(path.read_text(encoding="utf-8"))
        if not isinstance(config, dict):
            config = {}
    except json.JSONDecodeError:
        config = {}
else:
    config = {}

config["start_app_minimized"] = False
path.write_text(json.dumps(config, indent=2) + "\n", encoding="utf-8")
PY
}

stage_user_icon_theme
ensure_browser_environment
apply_user_flatpak_theme_overrides
install_flatpak_desktop_entries
ensure_protonvpn_visible_launch
copy_if_missing_or_legacy "${defaults_dir}/niri/config.kdl" "${HOME}/.config/niri/config.kdl" legacy_niri_config
ensure_niri_ghostty_launcher
ensure_niri_browser_bridge
copy_if_missing "${defaults_dir}/xdg/mimeapps.list" "${HOME}/.config/mimeapps.list"
copy_if_missing_or_legacy "${defaults_dir}/zed/settings.json" "${HOME}/.config/zed/settings.json" legacy_zed_settings
ensure_zed_settings
if [[ -d "${defaults_dir}/nvim" ]]; then
    while IFS= read -r nvim_default; do
        nvim_relative="${nvim_default#"${defaults_dir}/nvim/"}"
        copy_if_missing "${nvim_default}" "${HOME}/.config/nvim/${nvim_relative}"
    done < <(find "${defaults_dir}/nvim" -type f -print)
fi
copy_if_missing_or_legacy "${defaults_dir}/ghostty/config" "${HOME}/.config/ghostty/config" legacy_ghostty_config
ensure_ghostty_keep_warm
ensure_ghostty_user_service
copy_if_missing "${defaults_dir}/btop/btop.conf" "${HOME}/.config/btop/btop.conf"
copy_if_missing "${defaults_dir}/MangoHud/MangoHud.conf" "${HOME}/.config/MangoHud/MangoHud.conf"
copy_if_missing "${defaults_dir}/fish/config.fish" "${HOME}/.config/fish/config.fish"
copy_if_missing "${defaults_dir}/gtk-3.0/gtk.css" "${HOME}/.config/gtk-3.0/gtk.css"
copy_if_missing "${defaults_dir}/gtk-3.0/settings.ini" "${HOME}/.config/gtk-3.0/settings.ini"
copy_if_missing "${defaults_dir}/gtk-4.0/gtk.css" "${HOME}/.config/gtk-4.0/gtk.css"
copy_if_missing "${defaults_dir}/gtk-4.0/settings.ini" "${HOME}/.config/gtk-4.0/settings.ini"
ensure_gtk_settings
copy_if_missing "${defaults_dir}/qt6ct/qt6ct.conf" "${HOME}/.config/qt6ct/qt6ct.conf"
copy_if_missing "${defaults_dir}/switchyard/config.toml" "${HOME}/.var/app/io.github.alyraffauf.Switchyard/config/switchyard/config.toml"
nautilus_extensions_changed=0
for nautilus_extension in "${defaults_dir}"/nautilus/*.py; do
    [[ -f "${nautilus_extension}" ]] || continue
    nautilus_target="${HOME}/.local/share/nautilus-python/extensions/$(basename "${nautilus_extension}")"
    if [[ ! -e "${nautilus_target}" ]]; then
        install -D -m 0644 "${nautilus_extension}" "${nautilus_target}"
        nautilus_extensions_changed=1
    fi
done
if [[ "${nautilus_extensions_changed}" -eq 1 ]]; then
    rm -rf "${HOME}/.local/share/nautilus-python/extensions/__pycache__"
    pkill -x nautilus >/dev/null 2>&1 || true
fi

if command -v gsettings >/dev/null 2>&1; then
    gsettings set org.gnome.desktop.interface gtk-theme "adw-gtk3" || true
    gsettings set org.gnome.desktop.interface icon-theme "candy-icons" || true
    gsettings set org.gnome.desktop.interface color-scheme "prefer-dark" || true
    gsettings set org.gnome.desktop.privacy remember-recent-files false || true
    gsettings set org.gnome.desktop.privacy recent-files-max-age 0 || true
fi

if command -v xdg-mime >/dev/null 2>&1; then
    while IFS=$'\t' read -r mime desktop; do
        [[ -z "${mime}" || "${mime}" =~ ^# ]] && continue
        xdg-mime default "${desktop}" "${mime}" || true
    done < "${defaults_dir}/xdg/mime-defaults.tsv"
fi
if command -v xdg-settings >/dev/null 2>&1; then
    xdg-settings set default-web-browser io.github.alyraffauf.Switchyard.desktop || true
fi

touch "${state_dir}/user-defaults.done"
touch "${version_stamp}"
