legacy_ghostty_config() {
    grep -qx 'font-family = JetBrainsMono Nerd Font' "$1"
}

legacy_wallpaper_cache() {
    python3 - "$1" <<'PY'
import json
import sys

try:
    data = json.load(open(sys.argv[1], encoding="utf-8"))
except Exception:
    raise SystemExit(1)

raise SystemExit(0 if data.get("defaultWallpaper", "").startswith("/etc/xdg/quickshell/noctalia-shell/") else 1)
PY
}

legacy_noctalia_css() {
    grep -q 'Fallback until Noctalia renders generated GTK CSS for this user' "$1"
}

legacy_zed_settings() {
    python3 - "$1" <<'PY'
import json
import sys

try:
    data = json.load(open(sys.argv[1], encoding="utf-8"))
except Exception:
    raise SystemExit(1)

theme = data.get("theme", {})
is_previous_public_default = (
    theme.get("mode") == "system"
    and theme.get("light") == "One Light"
    and theme.get("dark") == "Noctalia"
    and data.get("buffer_font_family") == "JetBrainsMono Nerd Font"
    and data.get("ui_font_family") == "Inter"
)
raise SystemExit(0 if is_previous_public_default else 1)
PY
}

ensure_zed_settings() {
    local settings_path="${HOME}/.config/zed/settings.json"
    install -d -m 0755 "$(dirname "${settings_path}")"

    if [[ ! -e "${settings_path}" ]]; then
        install -D -m 0644 "${defaults_dir}/zed/settings.json" "${settings_path}"
        return 0
    fi

    python3 - "${settings_path}" <<'PY'
import json
import re
import sys
from pathlib import Path

path = Path(sys.argv[1])
text = path.read_text(encoding="utf-8")

def strip_jsonc(src: str) -> str:
    out = []
    i = 0
    in_string = False
    escape = False
    while i < len(src):
        ch = src[i]
        nxt = src[i + 1] if i + 1 < len(src) else ""
        if in_string:
            out.append(ch)
            if escape:
                escape = False
            elif ch == "\\":
                escape = True
            elif ch == '"':
                in_string = False
            i += 1
            continue
        if ch == '"':
            in_string = True
            out.append(ch)
            i += 1
            continue
        if ch == "/" and nxt == "/":
            i += 2
            while i < len(src) and src[i] not in "\r\n":
                i += 1
            continue
        if ch == "/" and nxt == "*":
            i += 2
            while i + 1 < len(src) and not (src[i] == "*" and src[i + 1] == "/"):
                i += 1
            i += 2
            continue
        out.append(ch)
        i += 1
    cleaned = "".join(out)
    return re.sub(r",\s*([}\]])", r"\1", cleaned)

try:
    data = json.loads(strip_jsonc(text) or "{}")
except Exception:
    raise SystemExit(0)

if not isinstance(data, dict):
    data = {}

wanted = {
    "mode": "system",
    "light": "Noctalia Light",
    "dark": "Noctalia Dark",
}

if data.get("theme") != wanted:
    data["theme"] = wanted
    path.write_text(json.dumps(data, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
PY
}

normalize_noctalia_browser_app_ids() {
    local settings_path="${HOME}/.config/noctalia/settings.json"
    [[ -f "${settings_path}" ]] || return 0

    python3 - "${settings_path}" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    raise SystemExit(0)

changed = False
for section in ("appLauncher", "dock"):
    apps = data.get(section, {}).get("pinnedApps")
    if not isinstance(apps, list):
        continue
    normalized = []
    for app in apps:
        if app == "firefox":
            app = "org.mozilla.firefox"
        if app == "torbrowser":
            continue
        normalized.append(app)
    if section == "appLauncher" and "trivalent" in normalized:
        trivalent_index = normalized.index("trivalent")
        for browser in ("com.brave.Origin.beta", "helium"):
            if browser not in normalized:
                trivalent_index += 1
                normalized.insert(trivalent_index, browser)
    if normalized != apps:
        data[section]["pinnedApps"] = normalized
        changed = True

if changed:
    path.write_text(json.dumps(data, indent=4, ensure_ascii=False) + "\n", encoding="utf-8")
PY
}

ensure_noctalia_network_widget() {
    local settings_path="${HOME}/.config/noctalia/settings.json"
    [[ -f "${settings_path}" ]] || return 0

    python3 - "${settings_path}" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    raise SystemExit(0)

if not isinstance(data, dict):
    raise SystemExit(0)

before = json.dumps(data, sort_keys=True, ensure_ascii=False)
bar = data.setdefault("bar", {})
if not isinstance(bar, dict):
    bar = {}
    data["bar"] = bar
widgets = bar.setdefault("widgets", {})
if not isinstance(widgets, dict):
    widgets = {}
    bar["widgets"] = widgets

network_widget = None
for section, items in list(widgets.items()):
    if not isinstance(items, list):
        continue
    kept = []
    for item in items:
        item_id = item.get("id") if isinstance(item, dict) else None
        if item_id == "VPN":
            continue
        if item_id == "Network":
            if network_widget is None:
                network_widget = item
            continue
        kept.append(item)
    widgets[section] = kept

screen_overrides = bar.get("screenOverrides", [])
if not isinstance(screen_overrides, list):
    screen_overrides = []
for override in screen_overrides:
    if not isinstance(override, dict):
        continue
    override_widgets = override.get("widgets")
    if not isinstance(override_widgets, dict):
        continue
    for section, items in list(override_widgets.items()):
        if isinstance(items, list):
            override_widgets[section] = [
                item
                for item in items
                if not (isinstance(item, dict) and item.get("id") == "VPN")
            ]

left = widgets.setdefault("left", [])
if not isinstance(left, list):
    left = []
    widgets["left"] = left

network_widget = network_widget or {"id": "Network"}
insert_at = len(left)
for index, item in enumerate(left):
    if isinstance(item, dict) and item.get("id") == "plugin:noctalia-calculator":
        insert_at = index + 1
        break
left.insert(insert_at, network_widget)

after = json.dumps(data, sort_keys=True, ensure_ascii=False)
if after != before:
    path.write_text(json.dumps(data, indent=4, ensure_ascii=False) + "\n", encoding="utf-8")
PY
}

ensure_noctalia_night_light_manual_default() {
    local settings_path="${HOME}/.config/noctalia/settings.json"
    [[ -f "${settings_path}" ]] || return 0

    python3 - "${settings_path}" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    raise SystemExit(0)

if not isinstance(data, dict):
    raise SystemExit(0)

night_light = data.get("nightLight")
location = data.get("location")
if not isinstance(night_light, dict) or not isinstance(location, dict):
    raise SystemExit(0)

if (
    night_light.get("enabled") is False
    and night_light.get("forced") is False
    and night_light.get("autoSchedule") is True
    and location.get("name", "") == ""
    and location.get("autoLocate") is False
):
    night_light["autoSchedule"] = False
    path.write_text(json.dumps(data, indent=4, ensure_ascii=False) + "\n", encoding="utf-8")
PY
}

ensure_noctalia_sddm_integration() {
    local settings_path="${HOME}/.config/noctalia/settings.json"
    [[ -f "${settings_path}" ]] || return 0

    python3 - "${settings_path}" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    raise SystemExit(0)

if not isinstance(data, dict):
    raise SystemExit(0)

before = json.dumps(data, sort_keys=True, ensure_ascii=False)

hooks = data.setdefault("hooks", {})
if not isinstance(hooks, dict):
    hooks = {}
    data["hooks"] = hooks
if not hooks.get("wallpaperChange"):
    hooks["wallpaperChange"] = "nocblue-sync-sddm-wallpaper"
if hooks.get("wallpaperChange") == "nocblue-sync-sddm-wallpaper":
    hooks["enabled"] = True

templates = data.setdefault("templates", {})
if not isinstance(templates, dict):
    templates = {}
    data["templates"] = templates
active = templates.setdefault("activeTemplates", [])
if not isinstance(active, list):
    active = []
    templates["activeTemplates"] = active
if not any(isinstance(item, dict) and item.get("id") == "sddm" for item in active):
    active.append({"enabled": True, "id": "sddm"})
templates["enableUserTheming"] = True

after = json.dumps(data, sort_keys=True, ensure_ascii=False)
if after != before:
    path.write_text(json.dumps(data, indent=4, ensure_ascii=False) + "\n", encoding="utf-8")
PY
}

ensure_noctalia_starship_integration() {
    local settings_path="${HOME}/.config/noctalia/settings.json"
    local apply_script=""
    local candidate

    if [[ -f "${settings_path}" ]]; then
        python3 - "${settings_path}" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    raise SystemExit(0)

if not isinstance(data, dict):
    raise SystemExit(0)

before = json.dumps(data, sort_keys=True, ensure_ascii=False)

templates = data.setdefault("templates", {})
if not isinstance(templates, dict):
    templates = {}
    data["templates"] = templates
active = templates.setdefault("activeTemplates", [])
if not isinstance(active, list):
    active = []
    templates["activeTemplates"] = active
if not any(isinstance(item, dict) and item.get("id") == "starship" for item in active):
    active.append({"enabled": True, "id": "starship"})
else:
    for item in active:
        if isinstance(item, dict) and item.get("id") == "starship":
            item["enabled"] = True
templates["enableUserTheming"] = True

after = json.dumps(data, sort_keys=True, ensure_ascii=False)
if after != before:
    path.write_text(json.dumps(data, indent=4, ensure_ascii=False) + "\n", encoding="utf-8")
PY
    fi

    for candidate in \
        "${HOME}/.config/quickshell/noctalia-shell/Scripts/bash/template-apply.sh" \
        "/etc/xdg/quickshell/noctalia-shell/Scripts/bash/template-apply.sh" \
        "/usr/share/quickshell/noctalia-shell/Scripts/bash/template-apply.sh"
    do
        if [[ -x "${candidate}" ]]; then
            apply_script="${candidate}"
            break
        fi
    done

    if [[ -n "${apply_script}" && -f "${HOME}/.cache/noctalia/starship-palette.toml" ]]; then
        PALETTE_FILE="${HOME}/.cache/noctalia/starship-palette.toml" "${apply_script}" starship || true
    fi
}

ensure_noctalia_pywalfox() {
    python3 - <<'PY'
import json
from pathlib import Path

template = {
    "wallpaper": "{{image}}",
    "alpha": "100",
    "colors": {
        "color0": "{{colors.surface.default.hex}}",
        "color1": "{{colors.error.default.hex}}",
        "color2": "{{colors.primary.default.hex}}",
        "color3": "{{colors.secondary.default.hex}}",
        "color4": "{{colors.tertiary.default.hex}}",
        "color5": "{{colors.primary_fixed_dim.default.hex}}",
        "color6": "{{colors.secondary_fixed_dim.default.hex}}",
        "color7": "{{colors.on_surface.default.hex}}",
        "color8": "{{colors.outline.default.hex}}",
        "color9": "{{colors.error.default.hex}}",
        "color10": "{{colors.primary.default.hex}}",
        "color11": "{{colors.secondary.default.hex}}",
        "color12": "{{colors.tertiary.default.hex}}",
        "color13": "{{colors.primary_fixed_dim.default.hex}}",
        "color14": "{{colors.secondary_fixed_dim.default.hex}}",
        "color15": "{{colors.on_surface.default.hex}}",
    },
}

home = Path.home()
wrapper = home / ".local/bin/pywalfox-native-messaging-host"
wrapper.parent.mkdir(parents=True, exist_ok=True)
wrapper.write_text(
    "#!/usr/bin/env bash\n"
    "unset LD_PRELOAD\n"
    "exec /usr/libexec/pywalfox-native-messaging-host-proxy \"$@\"\n",
    encoding="utf-8",
)
wrapper.chmod(0o755)

manifest = {
    "name": "pywalfox",
    "description": "Automatically theme your browser using the colors generated by Pywal",
    "path": str(wrapper),
    "type": "stdio",
    "allowed_extensions": ["pywalfox@frewacom.org"],
}
for path in (
    home / ".librewolf/native-messaging-hosts/pywalfox.json",
    home / ".mozilla/native-messaging-hosts/pywalfox.json",
    home / ".config/mozilla/native-messaging-hosts/pywalfox.json",
):
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(manifest, indent=2) + "\n", encoding="utf-8")

for path in (
    home / ".config/quickshell/noctalia-shell/Assets/Templates/pywalfox.json",
    home / ".local/share/quickshell/noctalia-shell/Assets/Templates/pywalfox.json",
):
    if not path.exists():
        continue
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        continue
    colors = data.get("colors")
    if not isinstance(colors, dict):
        continue
    if any(colors.get(f"color{i}", "") == "" for i in range(16)):
        path.write_text(json.dumps(template, indent=2) + "\n", encoding="utf-8")

cache = home / ".cache/wal/colors.json"
colors_path = home / ".config/noctalia/colors.json"
if cache.exists() and colors_path.exists():
    try:
        cache_data = json.loads(cache.read_text(encoding="utf-8"))
        noctalia = json.loads(colors_path.read_text(encoding="utf-8"))
    except Exception:
        cache_data = {}
        noctalia = {}

    colors = cache_data.get("colors")
    if isinstance(colors, dict) and any(colors.get(f"color{i}", "") == "" for i in range(16)):
        mapping = {
            "color0": "mSurface",
            "color1": "mError",
            "color2": "mPrimary",
            "color3": "mSecondary",
            "color4": "mTertiary",
            "color5": "mPrimary",
            "color6": "mSecondary",
            "color7": "mOnSurface",
            "color8": "mOutline",
            "color9": "mError",
            "color10": "mPrimary",
            "color11": "mSecondary",
            "color12": "mTertiary",
            "color13": "mPrimary",
            "color14": "mSecondary",
            "color15": "mOnSurface",
        }
        changed = False
        for color_key, noctalia_key in mapping.items():
            value = colors.get(color_key)
            fallback = noctalia.get(noctalia_key)
            if (not isinstance(value, str) or not value) and isinstance(fallback, str) and fallback:
                colors[color_key] = fallback
                changed = True
        if changed:
            cache.parent.mkdir(parents=True, exist_ok=True)
            cache.write_text(json.dumps(cache_data, indent=2) + "\n", encoding="utf-8")
PY

    if command -v pywalfox >/dev/null 2>&1; then
        pywalfox update >/dev/null 2>&1 || true
    fi
}

ensure_gtk_settings() {
    python3 - \
        "${HOME}/.config/gtk-3.0/settings.ini" \
        "${HOME}/.config/gtk-4.0/settings.ini" <<'PY'
from pathlib import Path
import sys

def rewrite_settings(path: Path, wanted: dict[str, str], remove: set[str]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    lines = path.read_text(encoding="utf-8").splitlines() if path.exists() else []

    settings_index = next((idx for idx, line in enumerate(lines) if line.strip() == "[Settings]"), None)
    if settings_index is None:
        lines = ["[Settings]", *lines]
        settings_index = 0

    end = len(lines)
    for idx in range(settings_index + 1, len(lines)):
        stripped = lines[idx].strip()
        if stripped.startswith("[") and stripped.endswith("]"):
            end = idx
            break

    block = lines[settings_index + 1 : end]
    out = []
    seen = set()
    changed = False

    for line in block:
        stripped = line.strip()
        if "=" not in stripped or stripped.startswith("#"):
            out.append(line)
            continue
        key, _ = stripped.split("=", 1)
        if key in remove:
            changed = True
            continue
        if key in wanted:
            replacement = f"{key}={wanted[key]}"
            if line != replacement:
                changed = True
            out.append(replacement)
            seen.add(key)
            continue
        out.append(line)

    for key, value in wanted.items():
        if key not in seen:
            out.append(f"{key}={value}")
            changed = True

    new_lines = lines[: settings_index + 1] + out + lines[end:]
    if changed or new_lines != lines:
        path.write_text("\n".join(new_lines) + "\n", encoding="utf-8")

rewrite_settings(
    Path(sys.argv[1]),
    {
        "gtk-theme-name": "adw-gtk3",
        "gtk-application-prefer-dark-theme": "1",
    },
    {"gtk-icon-theme-name"},
)
rewrite_settings(
    Path(sys.argv[2]),
    {"gtk-theme-name": "adw-gtk3"},
    {"gtk-icon-theme-name", "gtk-application-prefer-dark-theme"},
)
PY
}

legacy_niri_config() {
    grep -q 'spawn-at-startup "waybar"' "$1" && ! grep -q 'noctalia-shell' "$1"
}

legacy_noctalia_plugins() {
    python3 - "$1" <<'PY'
import json
import sys

try:
    data = json.load(open(sys.argv[1], encoding="utf-8"))
except Exception:
    raise SystemExit(1)

states = data.get("states", {})
expected = {
    "clipper": True,
    "file-search": True,
    "kaomoji-provider": True,
    "model-usage": False,
    "niri-animation-picker": True,
    "niri-overview-launcher": True,
    "noctalia-calculator": True,
    "notes-scratchpad": True,
    "polkit-agent": True,
    "pomodoro": True,
    "screen-recorder": True,
    "screen-toolkit": True,
    "timer": True,
    "todo": True,
    "weather-indicator": False,
}
is_previous_public_default = (
    set(states) == set(expected)
    and all(states[name].get("enabled") is enabled for name, enabled in expected.items())
)
raise SystemExit(0 if is_previous_public_default else 1)
PY
}

