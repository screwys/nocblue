legacy_ghostty_config() {
    grep -qx 'font-family = JetBrainsMono Nerd Font' "$1"
}

legacy_wallpaper_cache() {
    python3 - "$1" <<'PY'
import json
import sys

try:
    data = json.load(open(sys.argv[1], encoding="utf-8"))
except Exception:
    raise SystemExit(1)

raise SystemExit(0 if data.get("defaultWallpaper", "").startswith("/etc/xdg/quickshell/noctalia-shell/") else 1)
PY
}

legacy_noctalia_css() {
    grep -q 'Fallback until Noctalia renders generated GTK CSS for this user' "$1"
}

legacy_zed_settings() {
    python3 - "$1" <<'PY'
import json
import sys

try:
    data = json.load(open(sys.argv[1], encoding="utf-8"))
except Exception:
    raise SystemExit(1)

theme = data.get("theme", {})
is_previous_public_default = (
    theme.get("mode") == "system"
    and theme.get("light") == "One Light"
    and theme.get("dark") == "Noctalia"
    and data.get("buffer_font_family") == "JetBrainsMono Nerd Font"
    and data.get("ui_font_family") == "Inter"
)
raise SystemExit(0 if is_previous_public_default else 1)
PY
}

ensure_zed_settings() {
    local settings_path="${HOME}/.config/zed/settings.json"
    install -d -m 0755 "$(dirname "${settings_path}")"

    if [[ ! -e "${settings_path}" ]]; then
        install -D -m 0644 "${defaults_dir}/zed/settings.json" "${settings_path}"
        return 0
    fi

    python3 - "${settings_path}" <<'PY'
import json
import re
import sys
from pathlib import Path

path = Path(sys.argv[1])
text = path.read_text(encoding="utf-8")

def strip_jsonc(src: str) -> str:
    out = []
    i = 0
    in_string = False
    escape = False
    while i < len(src):
        ch = src[i]
        nxt = src[i + 1] if i + 1 < len(src) else ""
        if in_string:
            out.append(ch)
            if escape:
                escape = False
            elif ch == "\\":
                escape = True
            elif ch == '"':
                in_string = False
            i += 1
            continue
        if ch == '"':
            in_string = True
            out.append(ch)
            i += 1
            continue
        if ch == "/" and nxt == "/":
            i += 2
            while i < len(src) and src[i] not in "\r\n":
                i += 1
            continue
        if ch == "/" and nxt == "*":
            i += 2
            while i + 1 < len(src) and not (src[i] == "*" and src[i + 1] == "/"):
                i += 1
            i += 2
            continue
        out.append(ch)
        i += 1
    cleaned = "".join(out)
    return re.sub(r",\s*([}\]])", r"\1", cleaned)

try:
    data = json.loads(strip_jsonc(text) or "{}")
except Exception:
    raise SystemExit(0)

if not isinstance(data, dict):
    data = {}

wanted = {
    "mode": "system",
    "light": "Noctalia Light",
    "dark": "Noctalia Dark",
}

normalize_noctalia_firefox_app_id() {
    local settings_path="${HOME}/.config/noctalia/settings.json"
    [[ -f "${settings_path}" ]] || return 0

    python3 - "${settings_path}" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    raise SystemExit(0)

changed = False
for section in ("appLauncher", "dock"):
    apps = data.get(section, {}).get("pinnedApps")
    if not isinstance(apps, list):
        continue
    normalized = ["org.mozilla.firefox" if app == "firefox" else app for app in apps]
    if normalized != apps:
        data[section]["pinnedApps"] = normalized
        changed = True

if changed:
    path.write_text(json.dumps(data, indent=4, ensure_ascii=False) + "\n", encoding="utf-8")
PY
}
if data.get("theme") != wanted:
    data["theme"] = wanted
    path.write_text(json.dumps(data, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
PY
}

ensure_gtk_settings() {
    python3 - \
        "${HOME}/.config/gtk-3.0/settings.ini" \
        "${HOME}/.config/gtk-4.0/settings.ini" <<'PY'
from pathlib import Path
import sys

def rewrite_settings(path: Path, wanted: dict[str, str], remove: set[str]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    lines = path.read_text(encoding="utf-8").splitlines() if path.exists() else []

    settings_index = next((idx for idx, line in enumerate(lines) if line.strip() == "[Settings]"), None)
    if settings_index is None:
        lines = ["[Settings]", *lines]
        settings_index = 0

    end = len(lines)
    for idx in range(settings_index + 1, len(lines)):
        stripped = lines[idx].strip()
        if stripped.startswith("[") and stripped.endswith("]"):
            end = idx
            break

    block = lines[settings_index + 1 : end]
    out = []
    seen = set()
    changed = False

    for line in block:
        stripped = line.strip()
        if "=" not in stripped or stripped.startswith("#"):
            out.append(line)
            continue
        key, _ = stripped.split("=", 1)
        if key in remove:
            changed = True
            continue
        if key in wanted:
            replacement = f"{key}={wanted[key]}"
            if line != replacement:
                changed = True
            out.append(replacement)
            seen.add(key)
            continue
        out.append(line)

    for key, value in wanted.items():
        if key not in seen:
            out.append(f"{key}={value}")
            changed = True

    new_lines = lines[: settings_index + 1] + out + lines[end:]
    if changed or new_lines != lines:
        path.write_text("\n".join(new_lines) + "\n", encoding="utf-8")

rewrite_settings(
    Path(sys.argv[1]),
    {
        "gtk-theme-name": "adw-gtk3",
        "gtk-application-prefer-dark-theme": "1",
    },
    {"gtk-icon-theme-name"},
)
rewrite_settings(
    Path(sys.argv[2]),
    {"gtk-theme-name": "adw-gtk3"},
    {"gtk-icon-theme-name", "gtk-application-prefer-dark-theme"},
)
PY
}

legacy_niri_config() {
    grep -q 'spawn-at-startup "waybar"' "$1" && ! grep -q 'noctalia-shell' "$1"
}

legacy_noctalia_plugins() {
    python3 - "$1" <<'PY'
import json
import sys

try:
    data = json.load(open(sys.argv[1], encoding="utf-8"))
except Exception:
    raise SystemExit(1)

states = data.get("states", {})
expected = {
    "clipper": True,
    "file-search": True,
    "kaomoji-provider": True,
    "model-usage": False,
    "niri-animation-picker": True,
    "niri-overview-launcher": True,
    "noctalia-calculator": True,
    "notes-scratchpad": True,
    "polkit-agent": True,
    "pomodoro": True,
    "screen-recorder": True,
    "screen-toolkit": True,
    "timer": True,
    "todo": True,
    "weather-indicator": False,
}
is_previous_public_default = (
    set(states) == set(expected)
    and all(states[name].get("enabled") is enabled for name, enabled in expected.items())
)
raise SystemExit(0 if is_previous_public_default else 1)
PY
}

stage_user_icon_theme() {
    command -v nocblue-sync-icon-theme >/dev/null 2>&1 || return 0
    nocblue-sync-icon-theme || true
}

apply_user_flatpak_theme_overrides() {
    command -v flatpak >/dev/null 2>&1 || return 0

    flatpak override --user \
        --unset-env=GTK_THEME \
        --filesystem=xdg-config/gtk-3.0:ro \
        --filesystem=xdg-config/gtk-4.0:ro >/dev/null 2>&1 || true

    local app_id
    local themed_apps=(
        io.github.kolunmi.Bazaar
        com.belmoussaoui.Authenticator
        studio.planetpeanut.Bobby
        io.github.diegopvlk.Cine
        org.gnome.Papers
        org.gnome.gitlab.somas.Apostrophe
        org.gnome.Fractal
        io.github.ilya_zlobintsev.LACT
        io.github.radiolamp.mangojuice
        io.missioncenter.MissionCenter
        com.github.marhkb.Pods
        io.github.alyraffauf.Switchyard
        io.github.Foldex.AdwSteamGtk
        org.gnome.TextEditor
        it.mijorus.gearlever
    )

    for app_id in "${themed_apps[@]}"; do
        flatpak override --user \
            --unset-env=GTK_THEME \
            --filesystem=xdg-config/gtk-3.0:ro \
            --filesystem=xdg-config/gtk-4.0:ro \
            "${app_id}" >/dev/null 2>&1 || true
    done

    flatpak override --user \
        --unset-env=GTK_THEME \
        --env=SIGNAL_PASSWORD_STORE=gnome-libsecret \
        --filesystem=xdg-config/gtk-3.0:ro \
        --filesystem=xdg-config/gtk-4.0:ro \
        org.signal.Signal >/dev/null 2>&1 || true

    flatpak override --user \
        --unset-env=GTK_THEME \
        --filesystem=home \
        --filesystem=xdg-config/gtk-3.0:ro \
        --filesystem=xdg-config/gtk-4.0:ro \
        net.lutris.Lutris >/dev/null 2>&1 || true
}

noctalia_settings_changed=0
noctalia_templates_changed=0
stage_user_icon_theme
apply_user_flatpak_theme_overrides
if [[ ! -e "${HOME}/.config/noctalia/settings.json" ]] || legacy_noctalia_settings "${HOME}/.config/noctalia/settings.json"; then
    install -D -m 0644 "${defaults_dir}/noctalia/settings.json" "${HOME}/.config/noctalia/settings.json"
    noctalia_settings_changed=1
fi
normalize_noctalia_firefox_app_id
copy_if_missing_or_legacy "${defaults_dir}/noctalia/plugins.json" "${HOME}/.config/noctalia/plugins.json" legacy_noctalia_plugins
copy_if_missing "${defaults_dir}/noctalia/user-templates.toml" "${HOME}/.config/noctalia/user-templates.toml"
for noctalia_template in "${defaults_dir}"/noctalia/templates/*; do
    [[ -f "${noctalia_template}" ]] || continue
    noctalia_template_target="${HOME}/.config/noctalia/templates/$(basename "${noctalia_template}")"
    if [[ ! -e "${noctalia_template_target}" ]]; then
        install -D -m 0644 "${noctalia_template}" "${noctalia_template_target}"
        noctalia_templates_changed=1
    fi
done
if [[ -f "${HOME}/.config/noctalia/user-templates.toml" ]]; then
    user_templates="${HOME}/.config/noctalia/user-templates.toml"
    if grep -q '~/.var/app/com.valvesoftware.Steam/.steam/steam/steamui/skins/Material-Theme/css/main/colors/matugen.css' "${user_templates}"; then
        sed -i \
            's|~/.var/app/com.valvesoftware.Steam/.steam/steam/steamui/skins/Material-Theme/css/main/colors/matugen.css|~/.var/app/com.valvesoftware.Steam/.local/share/Steam/steamui/skins/Material-Theme/css/main/colors/matugen.css|g' \
            "${user_templates}"
        noctalia_templates_changed=1
    fi
    if python3 - "${user_templates}" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
lines = path.read_text(encoding="utf-8").splitlines(keepends=True)
out = []
changed = False
i = 0

while i < len(lines):
    if lines[i].strip() == "[templates.steam-flatpak]":
        j = i + 1
        while j < len(lines) and not lines[j].lstrip().startswith("["):
            j += 1
        block = lines[i:j]
        if any("Material-Theme" in line for line in block):
            changed = True
            if out and out[-1].strip() == "":
                out.pop()
            if j < len(lines) and lines[j].strip() != "":
                out.append("\n")
            i = j
            continue
    out.append(lines[i])
    i += 1

if changed:
    path.write_text("".join(out), encoding="utf-8")
raise SystemExit(0 if changed else 1)
PY
    then
        noctalia_templates_changed=1
    fi
    if ! grep -q '^\[templates\.adwsteamgtk-flatpak\]$' "${user_templates}"; then
        cat >> "${user_templates}" <<'EOF'

[templates.adwsteamgtk-flatpak]
input_path = "~/.config/noctalia/templates/adwsteamgtk.css"
output_path = "~/.var/app/io.github.Foldex.AdwSteamGtk/config/AdwSteamGtk/custom.css"
EOF
        noctalia_templates_changed=1
    fi
    if ! grep -q '^\[templates\.zed-native\]$' "${user_templates}"; then
        cat >> "${user_templates}" <<'EOF'

[templates.zed-native]
input_path = "/etc/xdg/quickshell/noctalia-shell/Assets/Templates/zed.json"
output_path = "~/.config/zed/themes/noctalia.json"
EOF
        noctalia_templates_changed=1
    fi
fi
copy_if_missing_or_legacy "${defaults_dir}/noctalia/cache/wallpapers.json" "${HOME}/.cache/noctalia/wallpapers.json" legacy_wallpaper_cache
for plugin_runtime in "${defaults_dir}"/noctalia/plugins/*/manifest.json; do
    [[ -f "${plugin_runtime}" ]] || continue
    plugin_name="$(basename "$(dirname "${plugin_runtime}")")"
    plugin_src="$(dirname "${plugin_runtime}")"
    plugin_dst="${HOME}/.config/noctalia/plugins/${plugin_name}"
    mkdir -p "${plugin_dst}"
    while IFS= read -r plugin_dir; do
        install -d "${plugin_dst}/${plugin_dir#./}"
    done < <(cd "${plugin_src}" && find . -type d -print)
    while IFS= read -r plugin_file; do
        [[ "${plugin_file}" == "./settings.json" ]] && continue
        if [[ ! -e "${plugin_dst}/${plugin_file#./}" ]]; then
            install -D -m 0644 "${plugin_src}/${plugin_file#./}" "${plugin_dst}/${plugin_file#./}"
        fi
    done < <(cd "${plugin_src}" && find . -type f -print)
done
for colorscheme in "${defaults_dir}"/noctalia/colorschemes/*/*.json; do
    [[ -f "${colorscheme}" ]] || continue
    scheme_name="$(basename "$(dirname "${colorscheme}")")"
    copy_if_missing "${colorscheme}" "${HOME}/.config/noctalia/colorschemes/${scheme_name}/$(basename "${colorscheme}")"
done
for plugin_settings in "${defaults_dir}"/noctalia/plugins/*/settings.json; do
    [[ -f "${plugin_settings}" ]] || continue
    plugin_name="$(basename "$(dirname "${plugin_settings}")")"
    copy_if_missing "${plugin_settings}" "${HOME}/.config/noctalia/plugins/${plugin_name}/settings.json"
done
copy_if_missing_or_legacy "${defaults_dir}/niri/config.kdl" "${HOME}/.config/niri/config.kdl" legacy_niri_config
copy_if_missing "${defaults_dir}/xdg/mimeapps.list" "${HOME}/.config/mimeapps.list"
copy_if_missing_or_legacy "${defaults_dir}/zed/settings.json" "${HOME}/.config/zed/settings.json" legacy_zed_settings
copy_if_missing "${defaults_dir}/zed/themes/noctalia.json" "${HOME}/.config/zed/themes/noctalia.json"
ensure_zed_settings
copy_if_missing_or_legacy "${defaults_dir}/ghostty/config" "${HOME}/.config/ghostty/config" legacy_ghostty_config
copy_if_missing "${defaults_dir}/ghostty/themes/noctalia" "${HOME}/.config/ghostty/themes/noctalia"
copy_if_missing "${defaults_dir}/btop/btop.conf" "${HOME}/.config/btop/btop.conf"
copy_if_missing "${defaults_dir}/fish/config.fish" "${HOME}/.config/fish/config.fish"
copy_if_missing "${defaults_dir}/gtk-3.0/gtk.css" "${HOME}/.config/gtk-3.0/gtk.css"
copy_if_missing_or_legacy "${defaults_dir}/gtk-3.0/noctalia.css" "${HOME}/.config/gtk-3.0/noctalia.css" legacy_noctalia_css
copy_if_missing "${defaults_dir}/gtk-3.0/settings.ini" "${HOME}/.config/gtk-3.0/settings.ini"
copy_if_missing "${defaults_dir}/gtk-4.0/gtk.css" "${HOME}/.config/gtk-4.0/gtk.css"
copy_if_missing_or_legacy "${defaults_dir}/gtk-4.0/noctalia.css" "${HOME}/.config/gtk-4.0/noctalia.css" legacy_noctalia_css
copy_if_missing "${defaults_dir}/gtk-4.0/settings.ini" "${HOME}/.config/gtk-4.0/settings.ini"
ensure_gtk_settings
copy_if_missing "${defaults_dir}/qt6ct/qt6ct.conf" "${HOME}/.config/qt6ct/qt6ct.conf"
copy_if_missing "${defaults_dir}/switchyard/config.toml" "${HOME}/.var/app/io.github.alyraffauf.Switchyard/config/switchyard/config.toml"
nautilus_extensions_changed=0
for nautilus_extension in "${defaults_dir}"/nautilus/*.py; do
    [[ -f "${nautilus_extension}" ]] || continue
    nautilus_target="${HOME}/.local/share/nautilus-python/extensions/$(basename "${nautilus_extension}")"
    if [[ ! -e "${nautilus_target}" ]]; then
        install -D -m 0644 "${nautilus_extension}" "${nautilus_target}"
        nautilus_extensions_changed=1
    fi
done
if [[ "${nautilus_extensions_changed}" -eq 1 ]]; then
    rm -rf "${HOME}/.local/share/nautilus-python/extensions/__pycache__"
    pkill -x nautilus >/dev/null 2>&1 || true
fi

if command -v gsettings >/dev/null 2>&1; then
    gsettings set org.gnome.desktop.interface gtk-theme "adw-gtk3" || true
    gsettings set org.gnome.desktop.interface icon-theme "candy-icons" || true
    gsettings set org.gnome.desktop.interface color-scheme "prefer-dark" || true
    gsettings set org.gnome.desktop.privacy remember-recent-files false || true
    gsettings set org.gnome.desktop.privacy recent-files-max-age 0 || true
fi

if command -v xdg-mime >/dev/null 2>&1; then
    while IFS=$'\t' read -r mime desktop; do
        [[ -z "${mime}" || "${mime}" =~ ^# ]] && continue
        xdg-mime default "${desktop}" "${mime}" || true
    done < "${defaults_dir}/xdg/mime-defaults.tsv"
fi
if command -v xdg-settings >/dev/null 2>&1; then
    xdg-settings set default-web-browser io.github.alyraffauf.Switchyard.desktop || true
fi

touch "${state_dir}/user-defaults.done"
touch "${version_stamp}"
