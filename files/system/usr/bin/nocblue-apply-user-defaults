            "${user_templates}"
        noctalia_templates_changed=1
    fi
    if python3 - "${user_templates}" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
lines = path.read_text(encoding="utf-8").splitlines(keepends=True)
out = []
changed = False
i = 0

while i < len(lines):
    if lines[i].strip() == "[templates.steam-flatpak]":
        j = i + 1
        while j < len(lines) and not lines[j].lstrip().startswith("["):
            j += 1
        block = lines[i:j]
        if any("Material-Theme" in line for line in block):
            changed = True
            if out and out[-1].strip() == "":
                out.pop()
            if j < len(lines) and lines[j].strip() != "":
                out.append("\n")
            i = j
            continue
    out.append(lines[i])
    i += 1

if changed:
    path.write_text("".join(out), encoding="utf-8")
raise SystemExit(0 if changed else 1)
PY
    then
        noctalia_templates_changed=1
    fi
    if ! grep -q '^\[templates\.adwsteamgtk-flatpak\]$' "${user_templates}"; then
        cat >> "${user_templates}" <<'EOF'

[templates.adwsteamgtk-flatpak]
input_path = "~/.config/noctalia/templates/adwsteamgtk.css"
output_path = "~/.var/app/io.github.Foldex.AdwSteamGtk/config/AdwSteamGtk/custom.css"
EOF
        noctalia_templates_changed=1
    fi
    if ! grep -q '^\[templates\.zed-native\]$' "${user_templates}"; then
