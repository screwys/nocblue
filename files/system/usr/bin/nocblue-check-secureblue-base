#!/usr/bin/env python3
import json
import sys
import urllib.request


def fetch_json(url, token, accept=None):
    headers = {"Authorization": f"Bearer {token}"}
    if accept:
        headers["Accept"] = accept
    request = urllib.request.Request(url, headers=headers)
    with urllib.request.urlopen(request, timeout=30) as response:
        digest = response.headers.get("Docker-Content-Digest")
        return digest, json.load(response)


def token_for(repo):
    url = f"https://ghcr.io/token?scope=repository:{repo}:pull&service=ghcr.io"
    with urllib.request.urlopen(url, timeout=30) as response:
        return json.load(response)["token"]


def image_info(repo, ref):
    token = token_for(repo)
    accept = ",".join(
        [
            "application/vnd.oci.image.index.v1+json",
            "application/vnd.docker.distribution.manifest.list.v2+json",
            "application/vnd.oci.image.manifest.v1+json",
            "application/vnd.docker.distribution.manifest.v2+json",
        ]
    )
    index_digest, manifest = fetch_json(
        f"https://ghcr.io/v2/{repo}/manifests/{ref}", token, accept
    )

    platform_digest = index_digest
    if "manifests" in manifest:
        amd64 = [
            entry
            for entry in manifest["manifests"]
            if entry.get("platform", {}).get("os") == "linux"
            and entry.get("platform", {}).get("architecture") == "amd64"
        ]
        if not amd64:
            raise SystemExit(f"{repo}:{ref} has no linux/amd64 manifest")
        platform_digest = amd64[0]["digest"]
        _, manifest = fetch_json(
            f"https://ghcr.io/v2/{repo}/manifests/{platform_digest}", token, accept
        )

    config_digest = manifest["config"]["digest"]
    _, config = fetch_json(f"https://ghcr.io/v2/{repo}/blobs/{config_digest}", token)
    labels = config.get("config", {}).get("Labels", {})
    return {
        "index": index_digest,
        "platform": platform_digest,
        "version": labels.get("org.opencontainers.image.version", "unknown"),
        "created": labels.get("org.opencontainers.image.created", "unknown"),
        "base": labels.get("org.opencontainers.image.base.digest", "unknown"),
        "base_name": labels.get("org.opencontainers.image.base.name", "unknown"),
    }


def main():
    upstream = image_info("secureblue/silverblue-main-hardened", "44")
    nocblue = image_info("screwys/nocblue-hardened", "44")

    print(f"secureblue 44: {upstream['version']} created {upstream['created']}")
    print(f"  index:    {upstream['index']}")
    print(f"  platform: {upstream['platform']}")
    print(f"nocblue-hardened 44: {nocblue['version']} created {nocblue['created']}")
    print(f"  index:    {nocblue['index']}")
    print(f"  platform: {nocblue['platform']}")
    print(f"  base:     {nocblue['base_name']} @ {nocblue['base']}")

    if nocblue["base"] in {upstream["platform"], upstream["index"]}:
        print("status: nocblue-hardened was built from the current secureblue 44 image")
        return 0

    print("status: nocblue-hardened is behind the current secureblue 44 image")
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
