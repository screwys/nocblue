#!/usr/bin/bash
set -euo pipefail

real_bwrap=/usr/bin/bwrap
codex_bwrap=/usr/libexec/nocblue/codex-bwrap/bwrap

is_codex_binary() {
    case "$1" in
        /var/home/linuxbrew/.linuxbrew/Caskroom/codex/*/codex-*-unknown-linux-musl|\
        /home/linuxbrew/.linuxbrew/Caskroom/codex/*/codex-*-unknown-linux-musl)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

caller="$(/usr/bin/readlink "/proc/${PPID}/exe" 2>/dev/null || true)"
if is_codex_binary "${caller}"; then
    exec "${codex_bwrap}" "$@"
fi

exec "${real_bwrap}" "$@"
