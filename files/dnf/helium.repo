[copr:copr.fedorainfracloud.org:imput:helium]
name=Copr repo for helium owned by imput
baseurl=https://download.copr.fedorainfracloud.org/results/imput/helium/fedora-$releasever-$basearch/
type=rpm-md
skip_if_unavailable=True
gpgcheck=1
gpgkey=https://download.copr.fedorainfracloud.org/results/imput/helium/pubkey.gpg
repo_gpgcheck=0
enabled=1
enabled_metadata=1
